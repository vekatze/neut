import {
  core.control {loop},
  core.list {fold-left-N},
  core.string-builder {append-string, extract, make-string-builder, string-builder},
}

data doc {
| Empty
| String(string, doc)
| Line(int, doc)
| Inline-Comment(string, doc)
}

constant indent: int {
  2
}

constant line: doc {
  Line(0, Empty)
}

inline make-string(t: string) -> doc {
  String(t, Empty)
}

inline inline-comment(t: string) -> doc {
  Inline-Comment(t, Empty)
}

define _join(d1: doc, d2: doc) -> doc {
  match d1 {
  | Empty =>
    d2
  | String(t, x) =>
    String(t, _join(x, d2))
  | Line(i, x) =>
    Line(i, _join(x, d2))
  | Inline-Comment(t, x) =>
    Inline-Comment(t, _join(x, d2))
  }
}

rule-right join {
  inline leaf(_: int) -> doc {
    Empty
  },
  inline node-left(d: doc, acc: doc) -> doc {
    _join(d, acc)
  },
  inline root<a>(x: a) -> a {
    x
  },
}

define join-doc-list(ds: list(doc)) -> doc {
  match ds {
  | Nil =>
    Empty
  | Cons(d, rest) =>
    _join(d, join-doc-list(rest))
  }
}

define nest(i: int, d: doc) -> doc {
  match d {
  | Empty =>
    Empty
  | String(t, x) =>
    String(t, nest(i, x))
  | Line(j, x) =>
    Line(add-int(i, j), nest(i, x))
  | Inline-Comment(t, x) =>
    Inline-Comment(t, nest(i, x))
  }
}

define _layout-direct(b: &string-builder, d: &doc) -> unit {
  case d {
  | Empty =>
    Unit
  | String(t, x) =>
    append-string(b, t);
    _layout-direct(b, x)
  | Line(i, x) =>
    append-string(b, "\n");
    loop(*i, (_) => {
      append-string(b, " ");
    });
    _layout-direct(b, x)
  | Inline-Comment(t, x) =>
    append-string(b, t);
    _layout-direct(b, x)
  }
}

define _slide-inline-comments(d: doc) -> doc {
  match d {
  | Empty =>
    Empty
  | String(t, x) =>
    String(t, _slide-inline-comments(x))
  | Line(i, x) =>
    match x {
    | Inline-Comment(t, cont) =>
      pin t = t;
      String(core.string.append(" ", t), _slide-inline-comments(cont))
    | x =>
      Line(i, _slide-inline-comments(x))
    }
  | Inline-Comment(t, x) =>
    Inline-Comment(t, _slide-inline-comments(x))
  }
}

define layout(d: doc) -> string {
  let b = make-string-builder(256);
  pin d = _slide-inline-comments(d);
  let _ on b = _layout-direct(b, d);
  extract(b)
}

define _is-multi(d: &doc) -> bool {
  case d {
  | Empty =>
    False
  | String(_, rest) =>
    _is-multi(rest)
  | Line {} =>
    True
  | Inline-Comment(_, rest) =>
    _is-multi(rest)
  }
}

define is-multi(ds: &list(doc)) -> bool {
  fold-left-N(False, ds, (acc, d) => {
    if acc {
      True
    } else {
      _is-multi(d)
    }
  })
}

define intercalate(!sep: doc, ds: list(doc)) -> doc {
  match ds {
  | Nil =>
    Empty
  | Cons(d, Nil) =>
    d
  | Cons(d, rest) =>
    join[d, sep, intercalate(sep, rest)]
  }
}

define zen() -> unit {
  pin d = List[Empty, Line(3, Empty)];
  pin b = is-multi(d);
  vet::(b);
}
