import {
  core.box {axiom-T},
  core.cell {borrow, make-cell, modify, mutate},
}

data gensym-kit {
| _Gensym-Kit(
    counter-ref: cell(int),
  )
}

define make-gensym-kit() -> gensym-kit {
  let counter-ref = make-cell(lift {0});
  _Gensym-Kit{counter-ref}
}

inline new-count(k: &gensym-kit) -> int {
  tie _Gensym-Kit{counter-ref} = k;
  modify(counter-ref, (x) => {
    let x = axiom-T(x);
    Pair(lift {add-int(x, 1)}, x)
  })
}

define set-count(k: &gensym-kit, x: int) -> unit {
  tie _Gensym-Kit{counter-ref} = k;
  mutate(counter-ref, (_) => {
    lift {x}
  })
}

define get-count(k: &gensym-kit) -> int {
  tie _Gensym-Kit{counter-ref} = k;
  borrow(counter-ref, (x) => {
    lift {*x}
  })
}

define zen() -> unit {
  pin k = make-gensym-kit();
  pin i = new-count(k);
  pin j = new-count(k);
  vet::(i);
  vet::(j);
  set-count(k, 10);
  pin i = new-count(k);
  vet::(i);
  set-count(k, 20);
  pin i = get-count(k);
  pin j = get-count(k);
  vet::(i);
  vet::(j);
}
