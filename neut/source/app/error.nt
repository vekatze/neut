import {
  this.logger.hint {hint},
  this.logger.log {Log, log, log-position-from-hint},
  this.logger.log-level {Critical, Error},
}

data error {
| Make-Error(vector(log))
}

define join(es: vector(error)) -> error {
  Make-Error(core.vector.concat(core.vector.for-each(es, (e, _) => {
    let Make-Error(rs) = e;
    rs
  })))
}

define new-error(m: hint, content: string) -> error {
  let m = log-position-from-hint(m);
  Make-Error(Vector[Log{content, level := Error, position := Right(m)}])
}

define new-error-prime(content: string) -> error {
  Make-Error(Vector[Log{content, level := Error, position := none}])
}

define new-critical(m: hint, content: string) -> error {
  let m = log-position-from-hint(m);
  Make-Error(Vector[Log{content, level := Critical, position := Right(m)}])
}

define new-critical-prime(content: string) -> error {
  Make-Error(Vector[Log{content, level := Critical, position := none}])
}
