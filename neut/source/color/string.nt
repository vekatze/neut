import {
  core.ansi {
    Background,
    Blue,
    Bold,
    Color,
    Color-16,
    Foreground,
    Italic,
    Normal,
    Red,
    Set-Style,
    Vivid,
    style,
  },
  core.string-builder {append-ansi, append-string, extract, make-string-builder},
}

data color-string {
| Empty
| Join(vector(style), string, color-string)
| Join-N(&vector(style), &string, color-string)
| Join-TN(&string, color-string)
}

define packed(ts: vector(style), t: string) -> color-string {
  Join(ts, t, Empty)
}

define packed-N(ts: &vector(style), t: &string) -> color-string {
  Join-N(ts, t, Empty)
}

define packed-empty(t: string) -> color-string {
  Join(core.vector.make(4), t, Empty)
}

define packed-N-empty(t: &string) -> color-string {
  Join-TN(t, Empty)
}

define _unpacked(t: &color-string) -> string {
  let b = make-string-builder(64);
  let _ on b = {
    let f =
      define loop(t: &color-string) -> unit {
        case t {
        | Empty =>
          Unit
        | Join(ts, t, rest) =>
          core.vector.for-N(ts, (t, _) => {
            append-ansi(b, Set-Style(*t));
          });
          append-string(b, t);
          append-ansi(b, Set-Style(Normal));
          loop(rest)
        | Join-N(ts, t, rest) =>
          core.vector.for-N(*ts, (t, _) => {
            append-ansi(b, Set-Style(*t));
          });
          append-string(b, *t);
          append-ansi(b, Set-Style(Normal));
          loop(rest)
        | Join-TN(t, rest) =>
          append-string(b, *t);
          loop(rest)
        }
      };
    f(t)
  };
  extract(b)
}

define _unpacked-uncolored(t: &color-string) -> string {
  let b = make-string-builder(256);
  let _ on b = {
    let f =
      define loop(t: &color-string) -> unit {
        case t {
        | Empty =>
          Unit
        | Join(_, t, rest) =>
          append-string(b, t);
          loop(rest)
        | Join-N(_, t, rest) =>
          append-string(b, *t);
          loop(rest)
        | Join-TN(t, rest) =>
          append-string(b, *t);
          loop(rest)
        }
      };
    f(t)
  };
  extract(b)
}

define join(t1: color-string, t2: color-string) -> color-string {
  match t1 {
  | Empty =>
    t2
  | Join(tones, content, rest) =>
    Join(tones, content, join(rest, t2))
  | Join-N(tones, content, rest) =>
    Join-N(tones, content, join(rest, t2))
  | Join-TN(t, rest) =>
    Join-TN(t, join(rest, t2))
  }
}

rule-right join-full {
  inline leaf(_: int) -> color-string {
    Empty
  },
  inline node-left(d: color-string, acc: color-string) -> color-string {
    join(d, acc)
  },
  inline root<a>(x: a) -> a {
    x
  },
}

define zen() -> unit {
  pin t =
    Join(
      Vector[Color(Foreground, Color-16(Vivid, Blue)), Bold],
      *"hello",
      Join(Vector[], *"\n", Empty),
    );
  pin fragment1 = _unpacked(t);
  pin fragment2 = _unpacked-uncolored(t);
  pin t-prime = packed(Vector[Color(Background, Color-16(Vivid, Red)), Italic], *"sample\n");
  pin fragment3 = _unpacked(t-prime);
  print(fragment1);
  print(fragment2);
  print(fragment3);
  print("sample\n")
}
