import {
  core.ansi {Blue, Bold, Color, Color-16, Foreground, Vivid},
  core.file.descriptor {descriptor, stderr, stdout},
  core.string {byte-length},
  core.string.pointer {get-content-pointer},
  this.color.color-kit {Color-Kit, color-kit, make-color-kit},
  this.color.string {color-string, packed, unpacked, unpacked-uncolored},
}

foreign {
  dprintf(int, pointer) -> void,
}

define _print(d: descriptor, t: &string) -> unit {
  let fmt = get-content-pointer("%.*s\0");
  let len = byte-length(t);
  let val = get-content-pointer(t);
  let _ = magic external dprintf(magic cast(descriptor, int, d), fmt)(len: int, val: pointer);
  Unit
}

define print-stdout(k: &color-kit, t: &color-string) -> unit {
  tie Color-Kit{colorize-stdout} = k;
  pin t-prime =
    if *colorize-stdout {
      unpacked(t)
    } else {
      unpacked-uncolored(t)
    };
  _print(stdout, t-prime)
}

define print-stderr(k: &color-kit, t: &color-string) -> unit {
  tie Color-Kit{colorize-stderr} = k;
  pin t-prime =
    if *colorize-stderr {
      unpacked(t)
    } else {
      unpacked-uncolored(t)
    };
  _print(stderr, t-prime)
}

define zen() -> unit {
  pin t-prime = packed(Vector[Color(Foreground, Color-16(Vivid, Blue)), Bold], *"sample\n");
  pin h = make-color-kit(False, True);
  print-stdout(h, t-prime);
  print-stderr(h, t-prime)
}
