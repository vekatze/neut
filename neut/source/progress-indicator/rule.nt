import {
  core.ansi {Color, Color-16, Foreground, Green, Vivid, style},
  core.control {grow},
  core.float {floor},
  core.int {min-int},
  core.int.show {show-int},
  core.string.io {print-line},
  this.color.string {Join-TN, _unpacked, color-string, join, packed, packed-N, packed-N-empty, packed-empty},
}

data progress-indicator {
| _Progress-Indicator(
    working-title: string,
    completed-title: string,
    color: vector(style),
    progress: ?pair(int, int),
  )
}

alias frame {
  int
}

define _choose-spinner(i: int) -> &string {
  match rem-int(i, 10) {
  | 0 =>
    "⠋"
  | 1 =>
    "⠙"
  | 2 =>
    "⠹"
  | 3 =>
    "⠸"
  | 4 =>
    "⠼"
  | 5 =>
    "⠴"
  | 6 =>
    "⠦"
  | 7 =>
    "⠧"
  | 8 =>
    "⠇"
  | _ =>
    "⠏"
  }
}

constant _bar-length: int {
  32
}

constant _bar-in-progress: &string {
  " "
}

constant _bar-finished: &string {
  "━"
}

define next(p: progress-indicator) -> progress-indicator {
  let _Progress-Indicator {working-title, completed-title, color, progress} = p;
  match progress {
  | Left(_) =>
    let progress = none;
    _Progress-Indicator {working-title, completed-title, color, progress}
  | Right(Pair(i, count)) =>
    let progress = Right(Pair(min-int(add-int(i, 1), count), count));
    _Progress-Indicator {working-title, completed-title, color, progress}
  }
}

define render-in-progress(i: frame, p: &progress-indicator) -> color-string {
  tie _Progress-Indicator {color, progress, working-title} = p;
  let spinner = packed-N(color, _choose-spinner(i));
  let title-prime = join(spinner, Join-TN(" ", packed-N-empty(working-title)));
  case progress {
  | Left(_) =>
    title-prime
  | Right(Pair(current, size)) =>
    let frac = div-float(sitofp-int-float(*current), sitofp-int-float(*size));
    let pivot = fptosi-float-int(floor(mul-float(sitofp-int-float(_bar-length), frac)));
    let prefix = packed(*color, core.string.replicate(_bar-finished, pivot));
    let suffix = packed-empty(core.string.replicate(_bar-in-progress, sub-int(_bar-length, pivot)));
    let bar = join(prefix, suffix);
    let current-prime = packed-empty(show-int(*current));
    let size-prime = packed-empty(show-int(*size));
    join(title-prime, Join-TN("\n ", join(bar, Join-TN(" ", join(current-prime, Join-TN("/", size-prime))))))
  }
}

define render-finished(p: &progress-indicator) -> color-string {
  tie _Progress-Indicator {color, completed-title} = p;
  let check = packed-N(color, "✓ ");
  let title = packed-N-empty(completed-title);
  join(check, join(title, packed-N-empty("\n")))
}

define zen() -> unit {
  let p =
    _Progress-Indicator {
      working-title := *"Working...",
      completed-title := *"Completed",
      color := Vector[Color(Foreground, Color-16(Vivid, Green))],
      progress := Right(Pair(0, 20)),
    };
  let p =
    grow(p, 30, (p, i) => {
      let _ on p = {
        let t = render-in-progress(i, p);
        pin t = t;
        pin k = _unpacked(t);
        print-line(k);
      };
      next(p)
    });
  let _ on p = {
    pin t = render-finished(p);
    pin t = _unpacked(t);
    print-line(t);
  };
  let _ = p;
  print-line("done");
  Unit
}
