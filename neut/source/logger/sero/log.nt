import {
  sero.decode {decode},
  sero.encode {encode},
  sero.get-kit {get-kit},
  sero.instance.either {either-sero},
  sero.instance.string {string-sero},
  sero.put-kit {put-kit},
  sero.sero {Sero, sero},
  this.logger.log {Log, log},
  this.logger.log-level {Note},
  this.logger.sero.log-level {log-level-sero},
  this.logger.sero.log-position {log-position-sero},
}

constant _unit-sero: sero(unit) {
  Sero{
    put := {
      (_, _) => {
        Unit
      }
    },
    get := {
      (_) => {
        Right(lift {Unit})
      }
    },
  }
}

define _put(k: &put-kit, v: &log) -> unit {
  let Sero{put := !put-option-hint} = either-sero(_unit-sero, log-position-sero);
  let Sero{put := !put-log-level} = log-level-sero;
  let Sero{put := !put-string} = string-sero;
  tie Log{position, level, content} = v;
  put-option-hint(k, position);
  put-log-level(k, level);
  put-string(k, content)
}

define _get(k: &get-kit) -> ?+log {
  let Sero{get := !get-option-hint} = either-sero(_unit-sero, log-position-sero);
  let Sero{get := !get-log-level} = log-level-sero;
  let Sero{get := !get-string} = string-sero;
  try position = get-option-hint(k);
  try level = get-log-level(k);
  try content = get-string(k);
  Right(box {
    letbox position = position;
    letbox level = level;
    letbox content = content;
    Log{position, level, content}
  })
}

constant log-sero: sero(log) {
  Sero{
    put := _put,
    get := _get,
  }
}

define zen() -> unit {
  pin val = Log{position := none, level := Note, content := *"some string"};
  let foo = decode(log-sero, encode(log-sero, val, 8));
  match foo {
  | Left(_) =>
    print("error\n")
  | Right(l) =>
    print("right\n");
    pin l = l;
    vet::(l)
  }
}
