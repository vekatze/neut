import {
  this.color.color-kit {color-kit},
  time.time {get-time, time},
}

data logger-kit {
| Logger-Kit(
    color-kit: color-kit,
    enable-debug-mode: bool,
    base-time: time,
  )
}

define show-time(m: time) -> string {
  time.time.show-time(m, 6)
}

define make-logger-kit(color-kit: color-kit, enable-debug-mode: bool) -> logger-kit {
  let base-time = get-time();
  Logger-Kit{color-kit, enable-debug-mode, base-time}
}

define get-color-kit(k: &logger-kit) -> &color-kit {
  tie Logger-Kit{color-kit} = k;
  color-kit
}
