import {
  core.ansi {Blue, Bold, Color, Color-16, Foreground, Magenta, Red, Vivid, style},
}

data log-level {
| Note
| Warning
| Error
| Critical
}

define _log-level-to-string(l: log-level) -> &string {
  match l {
  | Note =>
    "Note"
  | Warning =>
    "Warning"
  | Error =>
    "Error"
  | Critical =>
    "Critical"
  }
}

define _log-level-to-tone(l: log-level) -> vector(style) {
  match l {
  | Note =>
    Vector[Bold, Color(Foreground, Color-16(Vivid, Blue))]
  | Warning =>
    Vector[Bold, Color(Foreground, Color-16(Vivid, Magenta))]
  | Error =>
    Vector[Bold, Color(Foreground, Color-16(Vivid, Red))]
  | Critical =>
    Vector[Bold, Color(Foreground, Color-16(Vivid, Red))]
  }
}

define _log-level-to-pad(l: log-level) -> string {
  let len = core.string.length(_log-level-to-string(l));
  core.string.replicate(" ", add-int(len, 2))
}
