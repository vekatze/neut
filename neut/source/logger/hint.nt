data hint {
| Hint(
    file-path: &string,
    line: int,
    column: int,
    should-save-location: bool,
  )
| Saved-Hint(
    file-path: string,
    line: int,
    column: int,
    should-save-location: bool,
  )
}

define lift-hint(m: hint) -> +hint {
  match m {
  | Hint(path, line, column, should-save-location) =>
    box {
      letbox path = box path {path};
      letbox line = lift {line};
      letbox column = lift {column};
      letbox should-save-location = lift {should-save-location};
      Saved-Hint(path, line, column, should-save-location)
    }
  | Saved-Hint(a, b, c, d) =>
    box {
      letbox a = lift {a};
      letbox b = lift {b};
      letbox c = lift {c};
      letbox d = lift {d};
      Saved-Hint(a, b, c, d)
    }
  }
}

define get-line(m: &hint) -> int {
  case m {
  | Hint {line} =>
    *line
  | Saved-Hint {line} =>
    *line
  }
}

define get-column(m: &hint) -> int {
  case m {
  | Hint {column} =>
    *column
  | Saved-Hint {column} =>
    *column
  }
}

define get-file-path(m: &hint) -> &string {
  case m {
  | Hint {file-path} =>
    *file-path
  | Saved-Hint {file-path} =>
    file-path
  }
}

define get-should-save-location(m: &hint) -> bool {
  case m {
  | Hint {should-save-location} =>
    *should-save-location
  | Saved-Hint {should-save-location} =>
    *should-save-location
  }
}

define new-hint(line: int, column: int, file-path: &string) -> hint {
  Hint {
    file-path,
    line,
    column,
    should-save-location := True,
  }
}

define blur(m: hint) -> hint {
  match m {
  | Hint {file-path, line, column} =>
    Hint {
      file-path,
      line,
      column,
      should-save-location := False,
    }
  | Saved-Hint {file-path, line, column} =>
    Saved-Hint {
      file-path,
      line,
      column,
      should-save-location := False,
    }
  }
}

constant internal-hint: hint {
  Hint {
    file-path := "",
    line := 1,
    column := 1,
    should-save-location := False,
  }
}

define new-source-hint-N(file-path: &string) -> hint {
  new-hint(1, 1, file-path)
}

define new-source-hint(file-path: string) -> hint {
  Saved-Hint {
    file-path,
    line := 1,
    column := 1,
    should-save-location := True,
  }
}

define zen() -> unit {
  pin m = new-hint(12, 3456, "/Users/foo/path/to/file.nt");
  vet::(m)
  // printf("{}\n", List[show-file-pos(m)])
}
