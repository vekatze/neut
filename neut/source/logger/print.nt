import {
  core.ansi {Black, Color, Color-16, Foreground, Vivid},
  core.list {fold-right-N},
  this.color.color-kit {make-color-kit},
  this.color.print {print-stderr, print-stdout},
  this.color.string {join, packed, packed-empty},
  this.logger.hint {new-hint},
  this.logger.log {Log, _show-content, _show-level, _show-position, log, log-position-from-hint},
  this.logger.log-level {Note, Warning, log-level},
  this.logger.logger-kit {_Logger-Kit, _show-time, logger-kit, make-logger-kit},
  time.time {get-time, sub-time},
}

define print-log(k: &logger-kit, l: &log) -> unit {
  tie _Logger-Kit{color-kit} = k;
  tie Log{position, level, content} = l;
  let position-string = _show-position(position);
  let level-string = _show-level(*level);
  let content-string = _show-content{level := *level, content := *content};
  pin log-string = join(position-string, join(level-string, content-string));
  print-stdout(color-kit, log-string)
}

define print-log-error(k: &logger-kit, l: &log) -> unit {
  tie _Logger-Kit{color-kit} = k;
  tie Log{position, level, content} = l;
  let position-string = _show-position(position);
  let level-string = _show-level(*level);
  let content-string = _show-content{level := *level, content := *content};
  pin log-string = join(position-string, join(level-string, content-string));
  print-stderr(color-kit, log-string)
}

define print-log-list(k: &logger-kit, ls: &list(log)) -> unit {
  fold-right-N(ls, Unit, (l, _) => {
    print-log(k, l)
  })
}

define print-log-errors(k: &logger-kit, ls: &vector(log)) -> unit {
  core.vector.fold-right-N(ls, Unit, (l, _, _) => {
    print-log-error(k, l)
  })
}

define _print-log-without-position(k: &logger-kit, l: log-level, content: string) -> unit {
  pin l = Log{position := none, level := l, content};
  print-log(k, l)
}

define print-note(k: &logger-kit, content: string) -> unit {
  _print-log-without-position(k, Note, content)
}

define print-warning(k: &logger-kit, content: string) -> unit {
  _print-log-without-position(k, Warning, content)
}

define report(k: &logger-kit, message: string) -> unit {
  tie _Logger-Kit{color-kit, enable-debug-mode, base-time} = k;
  when *enable-debug-mode {
    let current-time = get-time();
    let elapsed-time = sub-time(current-time, *base-time);
    let time-string = packed(Vector[Color(Foreground, Color-16(Vivid, Black))], _show-time(elapsed-time));
    pin debug-string = join(time-string, join(packed-empty(*" "), join(packed-empty(message), packed-empty(*"\n"))));
    print-stderr(color-kit, debug-string)
  }
}

define zen() -> unit {
  let color-kit = make-color-kit(True, True);
  pin k = make-logger-kit(color-kit, True);
  let m = log-position-from-hint(new-hint(12, 3456, "/Users/foo/path/to/file.nt"));
  pin l =
    Log{
      position := Right(m),
      level := Note,
      content := *"Lorem ipsum.\nProin non hendrerit neque, id rhoncus nisi.",
    };
  print-log(k, l);
  print-warning(k, *"Nullam non dui a felis viverra molestie eget id mauris.");
  print-note(k, *"Aenean tortor ligula, efficitur id viverra ac, mattis in orci.\nDonec mattis ex quis scelerisque faucibus.");
  report(k, *"Donec sit amet euismod felis.\nVivamus ac lectus fermentum, blandit purus at, consectetur orci.")
}
