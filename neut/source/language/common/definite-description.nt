    string-from-strict-global-locator,
  },
  this.logger.hint {hint, internal-hint},
}

data definite-description {
| _Definite-Description(string)
}

constant eq-dd: eq(definite-description) {
  Eq{
    equal := {
      (x, y) => {
        tie _Definite-Description(x) = x;
        tie _Definite-Description(y) = y;
        eq-string(x, y)
      }
    },
  }
}

constant ord-dd: ord(definite-description) {
  let Ord{compare} = core.string.ord.as-ord;
  Ord{
    compare := {
      (x, y) => {
        tie _Definite-Description(x) = x;
        tie _Definite-Description(y) = y;
        compare(x, y)
      }
    },
  }
}

define new-dd(gl: &strict-global-locator, ll: local-locator) -> definite-description {
  pin tmp = string-from-strict-global-locator(gl);
  pin tmp = core.string.append(tmp, ns-sep);
  pin ll = string-from-local-locator(ll);
  let tmp = core.string.append(tmp, ll);
  _Definite-Description(tmp)
}

define new-dd-N(gl: &strict-global-locator, ll: &local-locator) -> definite-description {
  pin tmp = string-from-strict-global-locator(gl);
  pin tmp = core.string.append(tmp, ns-sep);
  let ll = string-from-local-locator-N(ll);
  let tmp = core.string.append(tmp, ll);
  _Definite-Description(tmp)
}

define string-from-dd(dd: &definite-description) -> &string {
  tie _Definite-Description(t) = dd;
  t
}

define _new-by-global-locator(gl: &strict-global-locator, name: base-name) -> definite-description {
  new-dd(gl, make-local-locator(name))
}

define _get-form-dd(dd: &definite-description) -> definite-description {
  tie _Definite-Description(t) = dd;
  pin tmp = core.string.append(t, "#");
  pin form = string-from-base-name(form());
  let tmp = core.string.append(tmp, form);
  _Definite-Description(tmp)
}

define _get-node-dd(dd: &definite-description) -> definite-description {
  tie _Definite-Description(t) = dd;
  pin tmp = core.string.append(t, "#");
  pin node = string-from-base-name(node());
  let tmp = core.string.append(tmp, node);
  _Definite-Description(tmp)
}

define _get-leaf-dd(dd: &definite-description) -> definite-description {
  tie _Definite-Description(t) = dd;
  pin tmp = core.string.append(t, "#");
  pin leaf = string-from-base-name(leaf());
  let tmp = core.string.append(tmp, leaf);
  _Definite-Description(tmp)
}

define _get-root-dd(dd: &definite-description) -> definite-description {
  tie _Definite-Description(t) = dd;
  pin tmp = core.string.append(t, "#");
  pin root = string-from-base-name(root());
  let tmp = core.string.append(tmp, root);
  _Definite-Description(tmp)
}

define uncons-dd(dd: &definite-description) -> pair(module-id, string) {
  tie _Definite-Description(t) = dd;
  let names = split(t, ns-sep);
  match names {
  | Cons(head-elem, rest) =>
    let b1 on head-elem = eq-string(head-elem, "this");
    let b2 on head-elem = eq-string(head-elem, "base");
    if b1 {
      Pair(Main, core.string.intercalate(rest, *ns-sep))
    } else-if b2 {
      Pair(Base, core.string.intercalate(rest, *ns-sep))
    } else {
      Pair(Library(Module-Digest(head-elem)), core.string.intercalate(rest, *ns-sep))
    }
  | _ =>
    panic("language.common.definite-description.uncons-dd")
  }
}

define global-locator-from-dd(dd: &definite-description) -> string {
  tie _Definite-Description(t) = dd;
  let names = split(t, ns-sep);
  match core.list.unsnoc(names) {
  | Right(Pair(xs, _)) =>
    core.string.intercalate(xs, *ns-sep)
  | _ =>
    panic("language.common.definite-description.global-locator-from-dd")
  }
}

define local-locator-from-dd(dd: &definite-description) -> string {
  tie _Definite-Description(t) = dd;
  let names = split(t, ns-sep);
  match core.list.unsnoc(names) {
  | Right(Pair(_, last)) =>
    last
  | _ =>
    panic("language.common.definite-description.local-locator-from-dd")
  }
}

