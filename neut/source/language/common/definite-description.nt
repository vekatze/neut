define append-dd(buf: &string-builder, dd: &definite-description) -> unit {
  tie _Definite-Description(t) = dd;
  append-string(buf, "\"");
  append-string(buf, t);
  append-string(buf, "\"");
}

define get-locator-pair(m: &hint, var-string: &string) -> app(pair(global-locator, local-locator)) {
  try names = base-name-by-split(m, var-string);
  match core.list.unsnoc(names) {
  | Left(_) =>
    raise-error(*m, *"lanugage.common.definite-description.get-locator-pair: empty variable name")
  | Right(Pair(Nil, _)) =>
    let buf = make-string-builder(64);
    let _ on buf = {
      append-string(buf, "The symbol `");
      append-string(buf, var-string);
      append-string(buf, "` does not contain a global locator");
    };
    raise-error(*m, core.string-builder.extract(buf))
  | Right(Pair(init-elems, last-elem)) =>
    try gl = _global-locator-from-base-name-list(m, init-elems);
    let ll = make-local-locator(last-elem);
    Right(Pair(gl, ll))
  }
}

constant llvm-global-locator-string: &string {
  "base.llvm"
}

constant definite-description-sero: sero(definite-description) {
  Sero{
    put := {
      (k, v) => {
        tie _Definite-Description(t) = v;
        put-string(k, t);
      }
    },
    get := {
      (k) => {
        try t = get-string(k);
        Right(box {
          letbox t = lift {t};
          _Definite-Description(t)
        })
      }
    },
  }
}

define zen() -> unit {
  pin m = internal-hint;
  pin v = get-locator-pair(m, "core.either.Left");
  vet::(v);
}
