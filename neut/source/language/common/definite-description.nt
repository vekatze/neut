  sero.sero {Sero, sero},
  this.app.app {app},
  this.app.run {raise-error},
  this.language.common.base-name {
    base-name,
    base-name-by-split,
    cls,
    form,
    imm-float16,
    imm-float32,
    imm-float64,
    imm-int1,
