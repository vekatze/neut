import {
  sero.sero {Sero, sero},
  this.language.common.ident {ident, ident-sero},
}

data binder-f(m, a) {
| Binder-F(m, ident, a)
}

inline binder-sero<m, a>(s1: sero(m), s2: sero(a)) -> sero(binder-f(m, a)) {
  let Sero {put := put-m, get := get-m} = s1;
  let Sero {put, get} = s2;
  Sero {
    put := {
      (k, v) => {
        let Sero {put := put-ident} = ident-sero;
        tie Binder-F(m, x, val) = v;
        put-m(k, m);
        put-ident(k, x);
        put(k, val);
      }
    },
    get := {
      (k) => {
        let Sero {get := get-ident} = ident-sero;
        try m = get-m(k);
        try x = get-ident(k);
        try val = get(k);
        Right(box {
          letbox m = m;
          letbox x = x;
          letbox val = val;
          Binder-F(m, x, val)
        })
      }
    },
  }
}
