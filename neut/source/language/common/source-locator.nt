import {
  core.list {for-each},
  core.string {replace},
  sero.common.get {get-string},
  sero.common.put {put-string},
  sero.sero {Sero, sero},
  this.language.common.base-name {base-name, string-from-base-name},
  this.language.common.const {ns-sep},
}

data source-locator {
| Source-Locator(string)
}

define string-from-source-locator(sl: &source-locator) -> string {
  tie Source-Locator(x) = sl;
  replace(x, "/", *ns-sep)
}

define source-locator-from-base-name-list(bns: list(base-name)) -> source-locator {
  Source-Locator(core.string.intercalate(for-each(bns, string-from-base-name), *"/"))
}

define llvm-locator() -> source-locator {
  Source-Locator(*"llvm")
}

define internal-locator() -> source-locator {
  Source-Locator(*"#")
}

define get-rel-path-string(sl: source-locator) -> string {
  let Source-Locator(x) = sl;
  x
}

constant source-locator-sero: sero(source-locator) {
  Sero{
    put := {
      (k, v) => {
        tie Source-Locator(x) = v;
        put-string(k, x);
      }
    },
    get := {
      (k) => {
        try t = get-string(k);
        Right(box {
          letbox t = lift {t};
          Source-Locator(t)
        })
      }
    },
  }
}
