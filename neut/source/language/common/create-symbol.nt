import {
  core.int.show {show-int},
  this.gensym.gensym {gensym-kit, make-gensym-kit, new-count},
  this.language.common.const {hole-var-prefix},
  this.language.common.ident {I, ident},
}

inline new-string-for-hole(k: &gensym-kit) -> string {
  let i = new-count(k);
  pin i = show-int(i);
  pin tmp = core.string.append(hole-var-prefix, ";");
  core.string.append(tmp, i)
}

inline new-ident-from-string(k: &gensym-kit, s: string) -> ident {
  let i = new-count(k);
  I(s, i)
}

inline new-string(k: &gensym-kit) -> string {
  new-string-for-hole(k)
}

inline new-ident-from-ident(k: &gensym-kit, x: &ident) -> ident {
  tie I(s, _) = x;
  new-ident-from-string(k, *s)
}

inline new-string-from-string(k: &gensym-kit, base: &string) -> string {
  let i = new-count(k);
  pin tmp = core.string.append(";", base);
  pin i = show-int(i);
  core.string.append(tmp, i)
}

inline new-ident-for-hole(k: &gensym-kit) -> ident {
  let t = new-string-for-hole(k);
  let i = new-count(k);
  I(t, i)
}

define zen() -> unit {
  pin k = make-gensym-kit();
  pin v = new-string-for-hole(k);
  vet::(v)
}
