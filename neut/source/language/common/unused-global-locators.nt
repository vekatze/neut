import {
  core.bool {all},
  this.logger.hint {hint},
}

alias unused-global-locators {
  list(pair(string, list(pair(hint, string))))
}

define _find(haystack: &list(pair(hint, string)), needle: &string) -> bool {
  case haystack {
  | Nil =>
    False
  | Cons(Pair(_, x), rest) =>
    if eq-string(x, needle) {
      True
    } else {
      _find(rest, needle)
    }
  }
}

define is-used-GL(unused: &unused-global-locators, cand: &string) -> bool {
  case unused {
  | Nil =>
    True
  | Cons(Pair(_, gls), rest) =>
    all[
      not(_find(gls, cand)),
      is-used-GL(rest, cand),
    ]
  }
}
