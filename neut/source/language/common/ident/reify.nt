import {
  core.int.show {show-int},
  this.language.common.ident {I, ident},
}

define string-from-ident(x: ident) -> string {
  let I(t, _) = x;
  t
}

define string-from-ident-debug(x: ident) -> string {
  let I(t, i) = x;
  pin t = t;
  pin i = show-int(i);
  pin tmp = core.string.append(t, "-");
  core.string.append(tmp, i)
}

define int-from-ident(x: &ident) -> int {
  tie I(_, i) = x;
  *i
}
