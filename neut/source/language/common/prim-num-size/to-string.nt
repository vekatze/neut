import {
  core.int.show {show-int},
  this.language.common.prim-num-size {float-size, int-from-float-size, int-from-int-size, int-size},
}

define string-from-int-size(x: int-size) -> string {
  pin t = show-int(int-from-int-size(x));
  core.string.append("int", t)
}

define string-from-float-size(x: float-size) -> string {
  pin t = show-int(int-from-float-size(x));
  core.string.append("float", t)
}
