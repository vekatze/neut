import {
  core.string-builder {append-string, string-builder},
  sero.common.get {get-string},
  sero.common.put {put-string},
  sero.get-kit {get-kit},
  sero.put-kit {put-kit},
  sero.sero {Sero, sero},
}

data external-name {
| External-Name(string)
}

define malloc-name() -> external-name {
  External-Name(*"malloc")
}

define free-name() -> external-name {
  External-Name(*"free")
}

define append-external-name(b: &string-builder, v: &external-name) -> unit {
  tie External-Name(t) = v;
  append-string(b, t)
}

constant external-name-sero: sero(external-name) {
  Sero{
    put := {
      (k: &put-kit, v: &external-name) => {
        tie External-Name(v) = v;
        put-string(k, v)
      }
    },
    get := {
      (k: &get-kit) => {
        try v = get-string(k);
        Right(lift {External-Name(v)})
      }
    },
  }
}
