import {
  core.bool {all},
  core.int.show {show-int},
  core.list {for-each-E},
  core.string {is-empty, string-byte-length},
  sero.common.get {get-string},
  sero.common.put {put-string},
  sero.sero {Sero, sero},
  this.app.error {error, new-error, new-error-prime},
  this.language.common.const {ns-sep},
  this.logger.hint {hint, internal-hint, lift-hint},
}

data base-name {
| _Base-Name(string)
| _Base-Name-N(string)
}

define _get-string(bn: &base-name) -> &string {
  case bn {
  | _Base-Name(t) =>
    t
  | _Base-Name-N(t) =>
    t
  }
}

constant ord-base-name: ord(base-name) {
  Ord{
    compare := {
      (x, y) => {
        let Ord{compare} = core.string.ord.as-ord;
        compare(_get-string(x), _get-string(y))
      }
    },
  }
}

define base-name-by-split(m: &hint, name: &string) -> either(error, list(base-name)) {
  for-each-E(core.string.split(name, ns-sep), (t) => {
    let b on t = is-empty(t);
    if b {
      Left(new-error(*m, core.string.append("No succeeding dots are allowed here: ", name)))
    } else {
      Right(_Base-Name(t))
    }
  })
}

define base-name-from-string(m: hint, name: &string) -> either(error, base-name) {
  let tmp = core.string.split(name, ns-sep);
  match tmp {
  | Cons(b, Nil) =>
    Right(_Base-Name(b))
  | _ =>
    Left(new-error(m, core.string.append("No dots are allowed here: ", name)))
  }
}

define base-name-from-string-meta(m: &hint, name: &string) -> +either(error, base-name) {
  let tmp = core.string.split(name, ns-sep);
  match tmp {
  | Cons(b, Nil) =>
    box {
      letbox b = lift {b};
      Right(_Base-Name(b))
    }
  | _ =>
    box {
      letbox m = lift-hint(*m);
      letbox name = box name {name};
      let message on name = core.string.append("No dots are allowed here: ", name);
      let _ = name;
      Left(new-error(m, message))
    }
  }
}

define base-name-from-string-unsafe(name: string) -> base-name {
  _Base-Name(name)
}

define base-name-from-string-without-hint(name: &string) -> either(error, base-name) {
  let tmp = core.string.split(name, ns-sep);
  match tmp {
  | Cons(b, Nil) =>
    Right(_Base-Name(b))
  | _ =>
    Left(new-error-prime(core.string.append("No dots are allowed here: ", name)))
  }
}

define string-from-base-name(bn: base-name) -> string {
  match bn {
  | _Base-Name(t) =>
    t
  | _Base-Name-N(t) =>
    t
  }
}

define string-from-base-name-N(bn: &base-name) -> &string {
  case bn {
  | _Base-Name(t) =>
    t
  | _Base-Name-N(t) =>
    t
  }
}

define _get-first-rune(t: &string) -> ?rune {
  let r = Right(Unit); // fixme
  try _ = r;
  if gt-int(string-byte-length(t), 0) {
    Right(core.string._get-rune(t, 0))
  } else {
    none
  }
}

define is-capitalized(bn: &base-name) -> bool {
  let t = _get-string(bn);
  if gt-int(string-byte-length(t), 0) {
    let r = core.string._get-rune(t, 0);
    all[le-rune(`A`, r), le-rune(r, `Z`)]
  } else {
    False
  }
}

define length(bn: &base-name) -> int {
  let t = _get-string(bn);
  core.string.length(t)
}

inline this() -> base-name {
  _Base-Name-N(*"this")
}

inline base() -> base-name {
  _Base-Name-N(*"base")
}

inline core() -> base-name {
  _Base-Name-N(*"core")
}

