define is-reserved-alias(k: &base-name) -> bool {
  let t = _get-string(k);
  pin this = this();
  pin base = base();
  if eq-string(t, _get-string(this)) {
    True
  } else-if eq-string(t, _get-string(base)) {
    True
  } else {
    False
  }
}

define extend(x: &base-name, y: &base-name) -> base-name {
  let t1 = _get-string(x);
  let t2 = _get-string(y);
  let tmp = core.string.append(t1, "#");
  let name on tmp = core.string.append(tmp, t2);
  let _ = tmp;
  _Base-Name(name)
}

constant base-name-sero: sero(base-name) {
  Sero{
    put := {
      (k, v) => {
        case v {
        | _Base-Name(t) =>
          put-string(k, t);
        | _Base-Name-N(t) =>
          put-string(k, t);
        }
      }
    },
    get := {
      (k) => {
        try t = get-string(k);
        Right(box {
          letbox t = lift {t};
          _Base-Name(t)
        })
      }
    },
  }
}

define zen() -> unit {
  pin v = base-name-from-string(internal-hint, "foo.bar");
  vet::(v);
  pin m = internal-hint;
  pin v = base-name-by-split(m, "foo.bar");
  vet::(v);
  pin bn = _Base-Name(*"Foo");
  pin v = is-capitalized(bn);
  vet::(v);
  pin bn = _Base-Name(*"foo");
  pin v = is-capitalized(bn);
  vet::(v);
  pin bn = _Base-Name(*"");
  pin v = is-capitalized(bn);
  vet::(v);
}
