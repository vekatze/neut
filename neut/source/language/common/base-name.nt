define sigma-name(i: int) -> base-name {
  let ti = show-int(i);
  let name on ti = core.string.append("sigma;", ti);
  let _ = ti;
  _Base-Name(name)
}

define lambda-name(name-or-none: ?string, i: int) -> base-name {
  let ti = show-int(i);
  match name-or-none {
  | Right(lam-name) =>
    let tmp on lam-name = core.string.append("lambda;", lam-name);
    let _ = lam-name;
    let name on tmp, ti = core.string.append(tmp, ti);
    let _ = tmp;
    let _ = ti;
    _Base-Name(name)
  | Left(_) =>
    let name on ti = core.string.append("lambda;anon;", ti);
    let _ = ti;
    _Base-Name(name)
  }
}

define mu-name(name: string, i: int) -> base-name {
  let ti = show-int(i);
  let tmp on name = core.string.append("mu;", name);
  let _ = name;
  let name on tmp, ti = core.string.append(tmp, ti);
  let _ = tmp;
  let _ = ti;
  _Base-Name(name)
}

define resource-name(i: int) -> base-name {
  let ti = show-int(i);
  let name on ti = core.string.append("resource;", ti);
  let _ = ti;
  _Base-Name(name)
}

define string-name(i: int) -> base-name {
  let ti = show-int(i);
  let name on ti = core.string.append("string;", ti);
  let _ = ti;
  _Base-Name(name)
}

