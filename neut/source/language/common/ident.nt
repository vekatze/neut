import {
  core.int.show {show-int},
  sero.common.get {get-int64, get-string},
  sero.common.put {put-int64, put-string},
  sero.sero {Sero, sero},
  this.language.common.const {exp-var-prefix, hole-var-prefix},
}

data ident {
| I(string, int)
}

define eq-ident(x: &ident, y: &ident) -> bool {
  tie I(_, x) = x;
  tie I(_, y) = y;
  eq-int(*x, *y)
}

define cmp-ident(x: &ident, y: &ident) -> ordering {
  tie I(_, x) = x;
  tie I(_, y) = y;
  if lt-int(*x, *y) {
    LT
  } else-if gt-int(*x, *y) {
    GT
  } else {
    EQ
  }
}

define length-ident(x: &ident) -> int {
  tie I(x, _) = x;
  core.string.length(x)
}

define show-ident(x: &ident) -> string {
  tie I(s, i) = x;
  pin i = show-int(*i);
  pin tmp = core.string.append("-", i);
  core.string.append(s, tmp)
}

define is-hole(x: &ident) -> bool {
  tie I(name, _) = x;
  core.string.eq.eq-prefix(name, hole-var-prefix)
}

define is-cartesian(x: &ident) -> bool {
  tie I(name, _) = x;
  core.string.eq.eq-prefix(name, exp-var-prefix)
}

constant ident-sero: sero(ident) {
  Sero {
    put := {
      (k, v) => {
        tie I(t, i) = v;
        put-string(k, t);
        put-int64(k, *i);
      }
    },
    get := {
      (k) => {
        try t = get-string(k);
        try i = get-int64(k);
        Right(box {
          letbox t = lift {t};
          letbox i = lift {i};
          I(t, i)
        })
      }
    },
  }
}

define zen() -> unit {
  pin x = I(*"{}test", 3);
  pin b = is-hole(x);
  vet::(b);
  pin b = is-cartesian(x);
  vet::(b);
  pin x = show-ident(x);
  vet::(x);
}
