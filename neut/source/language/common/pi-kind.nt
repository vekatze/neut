import {
  core.box {axiom-T},
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.instance.bool {bool-sero},
  sero.sero {Sero, sero},
  this.language.common.is-const-like {is-const-like},
}

data pi-kind {
| Normal(is-const-like)
| Data-Intro(is-const-like)
}

constant pi-kind-sero: sero(pi-kind) {
  let Sero {put} = bool-sero;
  Sero {
    put := {
      (k, v) => {
        case v {
        | Normal(b) =>
          put-int64(k, 0);
          put(k, b)
        | Data-Intro(b) =>
          put-int64(k, 1);
          put(k, b)
        }
      }
    },
    get := {
      (k) => {
        let Sero {get} = bool-sero;
        try tag = get-int64(k);
        try b = get(k);
        if eq-int(tag, 0) {
          Right(lift {Normal(axiom-T(b))})
        } else {
          Right(lift {Data-Intro(axiom-T(b))})
        }
      }
    },
  }
}

constant normal: pi-kind {
  Normal(False)
}
