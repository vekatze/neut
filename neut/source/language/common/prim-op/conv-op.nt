import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.sero {Sero, sero},
  this.language.common.prim-num-size {int-from-float-size, int-from-int-size},
  this.language.common.prim-type {Float, Int, prim-type},
}

data conv-op {
| Trunc
| Zext
| Sext
| Fptrunc
| Fpext
| Fptoui
| Fptosi
| Uitofp
| Sitofp
}

define show-conv-op(op: conv-op) -> &string {
  match op {
  | Trunc =>
    "trunc"
  | Zext =>
    "zext"
  | Sext =>
    "sext"
  | Fptrunc =>
    "fptrunc"
  | Fpext =>
    "fpext"
  | Fptoui =>
    "fptoui"
  | Fptosi =>
    "fptosi"
  | Uitofp =>
    "uitofp"
  | Sitofp =>
    "sitofp"
  }
}

define as-conv-op(name: &string, dom-type: &prim-type, cod-type: &prim-type) -> ?conv-op {
  case dom-type, cod-type {
  | Int(s1), Int(s2) =>
    let s1 = int-from-int-size(*s1);
    let s2 = int-from-int-size(*s2);
    if and(eq-string(name, "trunc"), gt-int(s1, s2)) {
      Right(Trunc)
    } else-if and(eq-string(name, "zext"), lt-int(s1, s2)) {
      Right(Zext)
    } else-if and(eq-string(name, "sext"), lt-int(s1, s2)) {
      Right(Sext)
    } else {
      none
    }
  | Int(_), Float(_) =>
    if eq-string(name, "uitofp") {
      Right(Trunc)
    } else-if eq-string(name, "sitofp") {
      Right(Zext)
    } else {
      none
    }
  | Float(_), Int(_) =>
    if eq-string(name, "fptoui") {
      Right(Trunc)
    } else-if eq-string(name, "fptosi") {
      Right(Zext)
    } else {
      none
    }
  | Float(s1), Float(s2) =>
    let s1 = int-from-float-size(*s1);
    let s2 = int-from-float-size(*s2);
    if and(eq-string(name, "fptrunc"), gt-int(s1, s2)) {
      Right(Fptrunc)
    } else-if and(eq-string(name, "fpext"), lt-int(s1, s2)) {
      Right(Fpext)
    } else {
      none
    }
  | _, _ =>
    none
  }
}

constant conv-op-sero: sero(conv-op) {
  Sero {
    put := {
      (k, v) => {
        put-int64(k, magic cast(&conv-op, int, v));
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        if and(le-int(0, tag), le-int(tag, 8)) {
          Right(lift {magic cast(int, conv-op, tag)})
        } else {
          none
        }
      }
    },
  }
}
