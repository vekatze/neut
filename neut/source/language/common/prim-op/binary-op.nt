import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.sero {Sero, sero},
}

data binary-op {
| Add
| Sub
| Mul
| SDiv
| SRem
| UDiv
| URem
| And
| Or
| Xor
| Shl
| Lshr
| Ashr
| FAdd
| FSub
| FMul
| FDiv
| FRem
}

define show-binary-op(op: binary-op) -> &string {
  match op {
  | Add =>
    "add"
  | Sub =>
    "sub"
  | Mul =>
    "mul"
  | SDiv =>
    "sdiv"
  | SRem =>
    "srem"
  | UDiv =>
    "udiv"
  | URem =>
    "urem"
  | And =>
    "and"
  | Or =>
    "or"
  | Xor =>
    "xor"
  | Shl =>
    "shl"
  | Lshr =>
    "lshr"
  | Ashr =>
    "ashr"
  | FAdd =>
    "fadd"
  | FSub =>
    "fsub"
  | FMul =>
    "fmul"
  | FDiv =>
    "fdiv"
  | FRem =>
    "frem"
  }
}

define binary-int-op-from-string(name: &string) -> ?binary-op {
  if eq-string(name, "add") {
    Right(Add)
  } else-if eq-string(name, "sub") {
    Right(Sub)
  } else-if eq-string(name, "mul") {
    Right(Mul)
  } else-if eq-string(name, "div") {
    Right(SDiv)
  } else-if eq-string(name, "rem") {
    Right(SRem)
  } else-if eq-string(name, "udiv") {
    Right(UDiv)
  } else-if eq-string(name, "urem") {
    Right(URem)
  } else-if eq-string(name, "and") {
    Right(And)
  } else-if eq-string(name, "or") {
    Right(Or)
  } else-if eq-string(name, "xor") {
    Right(Xor)
  } else-if eq-string(name, "shl") {
    Right(Shl)
  } else-if eq-string(name, "lshr") {
    Right(Lshr)
  } else-if eq-string(name, "ashr") {
    Right(Ashr)
  } else {
    none
  }
}

define binary-float-op-from-string(name: &string) -> ?binary-op {
  if eq-string(name, "add") {
    Right(FAdd)
  } else-if eq-string(name, "sub") {
    Right(FSub)
  } else-if eq-string(name, "mul") {
    Right(FMul)
  } else-if eq-string(name, "div") {
    Right(FDiv)
  } else-if eq-string(name, "rem") {
    Right(FRem)
  } else {
    none
  }
}

constant binary-op-sero: sero(binary-op) {
  Sero{
    put := {
      (k, v) => {
        put-int64(k, magic cast(&binary-op, int, v));
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        if and(le-int(0, tag), le-int(tag, 17)) {
          Right(lift {magic cast(int, binary-op, tag)})
        } else {
          none
        }
      }
    },
  }
}
