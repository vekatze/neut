import {
  sero.sero {Sero, sero},
}

data unary-op {
| FNeg
}

define show-unary-op(x: &unary-op) -> &string {
  case x {
  | FNeg =>
    "fneg"
  }
}

define unary-op-from-string(name: &string) -> ?unary-op {
  if eq-string(name, "fneg") {
    Right(FNeg)
  } else {
    none
  }
}

constant unary-op-sero: sero(unary-op) {
  Sero{
    put := {
      (_, _) => {
        Unit
      }
    },
    get := {
      (_) => {
        Right(box {FNeg})
      }
    },
  }
}
