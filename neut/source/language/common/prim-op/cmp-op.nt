import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.decode {decode},
  sero.encode {encode},
  sero.sero {Sero, sero},
}

data cmp-op {
| Eql
| Neq
| SGt
| SGe
| SLt
| SLe
| UGt
| UGe
| ULt
| ULe
| FOEq
| FONe
| FOGt
| FOGe
| FOLt
| FOLe
| FUEq
| FUGt
| FUGe
| FULt
| FULe
| FUNe
| FOrd
| FUno
| FTrue
| FFalse
}

define icmp(x: &string) -> string {
  core.string.append("icmp ", x)
}

define fcmp(x: &string) -> string {
  core.string.append("fcmp ", x)
}

define show-cmp-op(op: &cmp-op) -> string {
  case op {
  | Eql =>
    icmp("eq")
  | Neq =>
    icmp("ne")
  | SGt =>
    icmp("sgt")
  | SGe =>
    icmp("sge")
  | SLt =>
    icmp("slt")
  | SLe =>
    icmp("sle")
  | UGt =>
    icmp("ugt")
  | UGe =>
    icmp("uge")
  | ULt =>
    icmp("ult")
  | ULe =>
    icmp("ule")
  | FOEq =>
    fcmp("oeq")
  | FONe =>
    fcmp("one")
  | FOGt =>
    fcmp("ogt")
  | FOGe =>
    fcmp("oge")
  | FOLt =>
    fcmp("olt")
  | FOLe =>
    fcmp("ole")
  | FUEq =>
    fcmp("ueq")
  | FUGt =>
    fcmp("ugt")
  | FUGe =>
    fcmp("uge")
  | FULt =>
    fcmp("ult")
  | FULe =>
    fcmp("ule")
  | FUNe =>
    fcmp("une")
  | FOrd =>
    fcmp("ord")
  | FUno =>
    fcmp("uno")
  | FTrue =>
    fcmp("true")
  | FFalse =>
    fcmp("false")
  }
}

define int-cmp-op-from-string(name: &string) -> ?cmp-op {
  if eq-string(name, "eq") {
    Right(Eql)
  } else-if eq-string(name, "ne") {
    Right(Neq)
  } else-if eq-string(name, "gt") {
    Right(SGt)
  } else-if eq-string(name, "ge") {
    Right(SGe)
  } else-if eq-string(name, "lt") {
    Right(SLt)
  } else-if eq-string(name, "le") {
    Right(SLe)
  } else-if eq-string(name, "ugt") {
    Right(UGt)
  } else-if eq-string(name, "uge") {
    Right(UGe)
  } else-if eq-string(name, "ult") {
    Right(ULt)
  } else-if eq-string(name, "ule") {
    Right(ULe)
  } else {
    none
  }
}

define float-cmp-op-from-string(name: &string) -> ?cmp-op {
  if eq-string(name, "eq") {
    Right(FOEq)
  } else-if eq-string(name, "ne") {
    Right(FONe)
  } else-if eq-string(name, "gt") {
    Right(FOGt)
  } else-if eq-string(name, "ge") {
    Right(FOGe)
  } else-if eq-string(name, "lt") {
    Right(FOLt)
  } else-if eq-string(name, "le") {
    Right(FOLe)
  } else-if eq-string(name, "ueq") {
    Right(FUEq)
  } else-if eq-string(name, "une") {
    Right(FUNe)
  } else-if eq-string(name, "ugt") {
    Right(FUGt)
  } else-if eq-string(name, "uge") {
    Right(FUGe)
  } else-if eq-string(name, "ult") {
    Right(FULt)
  } else-if eq-string(name, "ule") {
    Right(FULe)
  } else-if eq-string(name, "ord") {
    Right(FOrd)
  } else-if eq-string(name, "uno") {
    Right(FUno)
  } else-if eq-string(name, "true") {
    Right(FTrue)
  } else-if eq-string(name, "false") {
    Right(FFalse)
  } else {
    none
  }
}

constant cmp-op-sero: sero(cmp-op) {
  Sero{
    put := {
      (k, v) => {
        put-int64(k, magic cast(&cmp-op, int, v));
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        if and(le-int(0, tag), le-int(tag, 25)) {
          Right(lift {magic cast(int, cmp-op, tag)})
        } else {
          none
        }
      }
    },
  }
}

define zen() -> unit {
  pin val = Eql;
  let k = encode(cmp-op-sero, val, 123);
  pin result = decode(cmp-op-sero, k);
  vet::(result);
  pin val = FFalse;
  let k = encode(cmp-op-sero, val, 123);
  pin result = decode(cmp-op-sero, k);
  vet::(result);
}
