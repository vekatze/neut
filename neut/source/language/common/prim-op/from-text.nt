import {
  core.string {break, drop, is-empty},
  this.language.common.data-size {Data-Size-64, data-size},
  this.language.common.definite-description {
    definite-description,
    global-locator-from-dd,
    llvm-global-locator-string,
    local-locator-from-dd,
  },
  this.language.common.prim-op {Prim-Binary-Op, Prim-Cmp-Op, Prim-Conv-Op, Prim-Unary-Op, prim-op},
  this.language.common.prim-op.binary-op {binary-float-op-from-string, binary-int-op-from-string},
  this.language.common.prim-op.cmp-op {float-cmp-op-from-string, int-cmp-op-from-string},
  this.language.common.prim-op.conv-op {as-conv-op},
  this.language.common.prim-op.unary-op {unary-op-from-string},
  this.language.common.prim-type {Float, Int},
  this.language.common.prim-type.from-string {prim-type-from-string},
}

define _break-hyphen(haystack: &string) -> ?pair(string, string) {
  if is-empty(haystack) {
    none
  } else {
    let Pair(h, t) = break(haystack, "-");
    let b on t = is-empty(t);
    if b {
      none
    } else {
      Right(Pair(h, drop(t, 1)))
    }
  }
}

define prim-op-from-string(ds: data-size, name: &string) -> ?prim-op {
  try Pair(op-str, type-str) = _break-hyphen(name);
  pin op-str = op-str;
  pin type-str = type-str;
  match _break-hyphen(type-str) {
  | Right(Pair(dom-type-str, cod-type-str)) =>
    pin dom-type-str = dom-type-str;
    pin cod-type-str = cod-type-str;
    try dom-type = prim-type-from-string(ds, dom-type-str);
    try cod-type = prim-type-from-string(ds, cod-type-str);
    try conv-op on dom-type, cod-type = as-conv-op(op-str, dom-type, cod-type);
    Right(Prim-Conv-Op(conv-op, dom-type, cod-type))
  | _ =>
    try prim-type = prim-type-from-string(ds, type-str);
    match prim-type {
    | Int(size) =>
      match binary-int-op-from-string(op-str) {
      | Right(op) =>
        Right(Prim-Binary-Op(op, Int(size), Int(size)))
      | _ =>
        try op = int-cmp-op-from-string(op-str);
        Right(Prim-Cmp-Op(op, Int(size), Int(size)))
      }
    | Float(size) =>
      match binary-float-op-from-string(op-str) {
      | Right(op) =>
        Right(Prim-Binary-Op(op, Float(size), Float(size)))
      | _ =>
        match unary-op-from-string(op-str) {
        | Right(op) =>
          Right(Prim-Unary-Op(op, Float(size), Float(size)))
        | _ =>
          try op = float-cmp-op-from-string(op-str);
          Right(Prim-Cmp-Op(op, Float(size), Float(size)))
        }
      }
    | _ =>
      none
    }
  }
}

define prim-op-from-definite-description(ds: data-size, dd: &definite-description) -> ?prim-op {
  pin sgl = global-locator-from-dd(dd);
  let b = eq-string(llvm-global-locator-string, sgl);
  if b {
    pin ll = local-locator-from-dd(dd);
    prim-op-from-string(ds, ll)
  } else {
    none
  }
}

define zen() -> unit {
  pin result = _break-hyphen("add-int");
  vet::(result);
  pin result = _break-hyphen("int");
  vet::(result);
  pin v = prim-op-from-string(Data-Size-64, "add-int");
  vet::(v);
  pin v = prim-op-from-string(Data-Size-64, "sub-int32");
  vet::(v);
  pin v = prim-op-from-string(Data-Size-64, "shl-int8");
  vet::(v);
  pin v = prim-op-from-string(Data-Size-64, "fptosi-float-int");
  vet::(v);
}
