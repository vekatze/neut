import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.instance.either {either-sero},
  sero.instance.string {string-sero},
  sero.sero {Sero, sero},
  this.language.common.binder {binder-f, binder-sero},
  this.logger.sero.log {_unit-sero},
}

data lam-kind-f(m, a) {
| Normal(?string, a)
| Fix(binder-f(m, a))
}

define from-lam-kind<m, a>(k: &lam-kind-f(m, a)) -> ?&binder-f(m, a) {
  case k {
  | Fix(x) =>
    Right(x)
  | _ =>
    none
  }
}

inline lam-kind-sero<m, a>(!sm: sero(m), !s: sero(a)) -> sero(lam-kind-f(m, a)) {
  let Sero{put := put-a, get := get-a} = s;
  Sero{
    put := {
      (k, v) => {
        case v {
        | Normal(t, x) =>
          let Sero{put} = either-sero(_unit-sero, string-sero);
          put-int64(k, 0);
          put(k, t);
          put-a(k, x);
        | Fix(x) =>
          let Sero{put := put-binder} = binder-sero(sm, s);
          put-int64(k, 1);
          put-binder(k, x);
        }
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        match tag {
        | 0 =>
          let Sero{get} = either-sero(_unit-sero, string-sero);
          try t = get(k);
          try x = get-a(k);
          Right(box {
            letbox t = t;
            letbox x = x;
            Normal(t, x)
          })
        | 1 =>
          let Sero{get := get-binder} = binder-sero(sm, s);
          try b = get-binder(k);
          Right(box {
            letbox b = b;
            Fix(b)
          })
        | _ =>
          none
        }
      }
    },
  }
}
