import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.sero {Sero, sero},
  this.language.common.binder {binder-f},
  this.language.common.lam-kind {Normal, from-lam-kind, lam-kind-f, lam-kind-sero},
}

alias _ID {
  int
}

data attr-lam(m, a) {
| Attr-Lam(
    lam-kind: lam-kind-f(m, a),
    identity: _ID,
  )
}

define normal<m, a>(i: _ID, cod-type: a) -> attr-lam(m, a) {
  Attr-Lam {
    lam-kind := Normal(none, cod-type),
    identity := i,
  }
}

define normal-with-name<m, a>(name: ?string, i: _ID, cod-type: a) -> attr-lam(m, a) {
  Attr-Lam {
    lam-kind := Normal(name, cod-type),
    identity := i,
  }
}

define binder-from-attr-lam<m, a>(attr: &attr-lam(m, a)) -> ?&binder-f(m, a) {
  tie Attr-Lam {lam-kind} = attr;
  from-lam-kind(lam-kind)
}

inline attr-lam-sero<m, a>(!sm: sero(m), a-sero: sero(a)) -> sero(attr-lam(m, a)) {
  let Sero {put := put-lam-kind, get := get-lam-kind} = lam-kind-sero(sm, a-sero);
  Sero {
    put := {
      (k, v) => {
        tie Attr-Lam(lam-kind, i) = v;
        put-lam-kind(k, lam-kind);
        put-int64(k, *i);
      }
    },
    get := {
      (k) => {
        try lam-kind = get-lam-kind(k);
        try i = get-int64(k);
        Right(box {
          letbox lam-kind = lam-kind;
          letbox i = lift {i};
          Attr-Lam(lam-kind, i)
        })
      }
    },
  }
}
