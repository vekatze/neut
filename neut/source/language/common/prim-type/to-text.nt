import {
  this.language.common.prim-num-size.to-string {string-from-float-size, string-from-int-size},
  this.language.common.prim-type {Float, Int, Pointer, Rune, prim-type},
}

define string-from-prim-type(pt: &prim-type) -> string {
  case pt {
  | Int(int-size) =>
    string-from-int-size(*int-size)
  | Float(float-size) =>
    string-from-float-size(*float-size)
  | Rune =>
    *"rune"
  | Pointer =>
    *"pointer"
  }
}
