import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.get-kit {get-kit},
  sero.put-kit {put-kit},
  sero.sero {Sero, sero},
}

data opacity {
| Opaque
| Clear
}

define is-opaque(o: opacity) -> bool {
  match o {
  | Opaque =>
    True
  | Clear =>
    False
  }
}

constant opacity-sero: sero(opacity) {
  Sero{
    put := {
      (k: &put-kit, v: &opacity) => {
        case v {
        | Opaque =>
          put-int64(k, 0)
        | Clear =>
          put-int64(k, 1)
        }
      }
    },
    get := {
      (k: &get-kit) => {
        try v = get-int64(k);
        match v {
        | 0 =>
          Right(lift {Opaque})
        | 1 =>
          Right(lift {Clear})
        | _ =>
          none
        }
      }
    },
  }
}
