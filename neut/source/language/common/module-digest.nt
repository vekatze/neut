import {
  core.binary {binary},
  sero.common.get {get-string},
  sero.common.put {put-string},
  sero.sero {Sero, sero},
  this.language.common.digest {hash-and-encode},
}

data module-digest {
| Module-Digest(string)
}

define string-from-module-digest(m: &module-digest) -> &string {
  tie Module-Digest(t) = m;
  t
}

define module-digest-from-binary(b: &binary) -> module-digest {
  Module-Digest(hash-and-encode(b))
}

constant module-digest-sero: sero(module-digest) {
  Sero {
    put := {
      (k, v) => {
        tie Module-Digest(t) = v;
        put-string(k, t);
      }
    },
    get := {
      (k) => {
        try t = get-string(k);
        Right(box {
          letbox t = lift {t};
          Module-Digest(t)
        })
      }
    },
  }
}
