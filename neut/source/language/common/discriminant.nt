import {
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.sero {Sero, sero},
}

data discriminant {
| Discriminant(int)
}

constant zero-discriminant: discriminant {
  Discriminant(0)
}

define increment-discriminant(d: discriminant) -> discriminant {
  let Discriminant(x) = d;
  Discriminant(add-int(x, 1))
}

constant discriminant-sero: sero(discriminant) {
  Sero{
    put := {
      (k, v) => {
        tie Discriminant(x) = v;
        put-int64(k, *x);
      }
    },
    get := {
      (k) => {
        try x = get-int64(k);
        Right(lift {Discriminant(x)})
      }
    },
  }
}
