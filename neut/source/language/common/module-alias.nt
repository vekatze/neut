import {
  sero.sero {Sero, sero},
  this.language.common.base-name {base, base-name, base-name-sero, core, ord-base-name, string-from-base-name, this},
}

data module-alias {
| Module-Alias(base-name)
}

constant ord-module-alias: ord(module-alias) {
  Ord{
    compare := {
      (x, y) => {
        let Ord{compare} = ord-base-name;
        tie Module-Alias(x) = x;
        tie Module-Alias(y) = y;
        compare(x, y)
      }
    },
  }
}

define default-module-alias() -> module-alias {
  Module-Alias(this())
}

define core-module-alias() -> module-alias {
  Module-Alias(core())
}

define base-module-alias() -> module-alias {
  Module-Alias(base())
}

define string-from-module-alias(alias: module-alias) -> string {
  let Module-Alias(bn) = alias;
  string-from-base-name(bn)
}

constant module-alias-sero: sero(module-alias) {
  Sero{
    put := {
      (k, v) => {
        let Sero{put} = base-name-sero;
        tie Module-Alias(base-name) = v;
        put(k, base-name)
      }
    },
    get := {
      (k) => {
        let Sero{get} = base-name-sero;
        try bn = get(k);
        Right(box {
          letbox bn = bn;
          Module-Alias(bn)
        })
      }
    },
  }
}
