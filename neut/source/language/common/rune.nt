import {
  core.string.parse {Parse-Error, parse-string},
}

define rune-from-string(x: &string) -> either(string, rune) {
  match parse-string(x) {
  | Left(Parse-Error(reason)) =>
    pin reason = reason;
    pin tmp = core.string.append("Could not interpret the following as a rune: ", x);
    pin tmp2 = core.string.append(tmp, "\nReason: ");
    Left(core.string.append(tmp2, reason))
  | Right(x) =>
    match core.string.uncons(x) {
    | Left(_) =>
      Left(*"The content a rune literal must be length 1")
    | Right(Pair(r, rest)) =>
      pin rest = rest;
      if eq-int(core.string.length(rest), 0) {
        Right(r)
      } else {
        Left(*"The content a rune literal must be length 1")
      }
    }
  }
}

define zen() -> unit {
  pin foo = rune-from-string("あ");
  vet::(foo);
}
