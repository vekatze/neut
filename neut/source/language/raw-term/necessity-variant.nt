data necessity-variant {
| Variant-K
| Variant-T
}

define string-from-necessity-variant(nv: necessity-variant) -> &string {
  match nv {
  | Variant-K =>
    "letbox"
  | Variant-T =>
    "letbox-T"
  }
}

define necessity-variant-from-string(t: &string) -> ?necessity-variant {
  if eq-string(t, "letbox") {
    Right(Variant-K)
  } else-if eq-string(t, "letbox-T") {
    Right(Variant-T)
  } else {
    none
  }
}

define layer-offset(nv: necessity-variant) -> int {
  match nv {
  | Variant-K =>
    1
  | Variant-T =>
    0
  }
}
