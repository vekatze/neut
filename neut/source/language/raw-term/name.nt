import {
  this.language.raw-term.locator {locator, string-from-locator},
  this.language.raw-term.raw-ident {raw-ident},
}

data name {
| Var(raw-ident)
| Locator(locator)
}

define string-from-name(n: &name) -> string {
  case n {
  | Var(x) =>
    *x
  | Locator(l) =>
    string-from-locator(l)
  }
}

define _is-upper(r: rune) -> bool {
  and(le-rune(`A`, r), le-rune(r, `Z`))
}

define is-cons-name(x: &string) -> bool {
  let tmp =
    core.string.drop-while-N(x, (r) => {
      eq-rune(r, `_`)
    });
  match core.string.uncons(tmp) {
  | Right(Pair(c, _)) =>
    _is-upper(c)
  | _ =>
    False
  }
}

define zen() -> unit {
  pin a = _is-upper(`A`);
  pin x = _is-upper(`X`);
  pin z = _is-upper(`Z`);
  pin w = _is-upper(`w`);
  vet::(a);
  vet::(x);
  vet::(z);
  vet::(w);
}
