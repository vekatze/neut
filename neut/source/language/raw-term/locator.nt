import {
  this.language.common.const {ns-sep},
  this.language.common.global-locator {global-locator, string-from-global-locator},
  this.language.common.local-locator {local-locator, string-from-local-locator-N},
}

alias locator {
  pair(global-locator, local-locator)
}

define string-from-locator(l: &locator) -> string {
  tie Pair(gl, ll) = l;
  pin gl = string-from-global-locator(gl);
  let ll = string-from-local-locator-N(ll);
  pin tmp = core.string.append(gl, ns-sep);
  core.string.append(tmp, ll)
}
