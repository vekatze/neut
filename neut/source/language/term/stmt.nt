import {
  core.list {filter-some, for-each-N},
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.instance.bool {bool-sero},
  sero.instance.either {either-sero},
  sero.instance.list {list-sero},
  sero.instance.pair {pair-sero},
  sero.instance.unit {unit-sero},
  sero.sero {Sero, sero},
  this.language.common.binder {binder-f, binder-sero},
  this.language.common.definite-description {definite-description, definite-description-sero},
  this.language.common.discriminant {discriminant},
  this.language.common.is-const-like {is-const-like},
  this.language.common.stmt-kind {base-stmt-kind-sero, stmt-kind},
  this.language.term.term {term, term-f},
  this.logger.hint {hint},
  this.logger.log {log-position},
  this.logger.sero.log-position {log-position-sero},
}

data stmt-f(mt, a) {
| Stmt-Define(
    b: is-const-like,
    sk: stmt-kind(mt, a),
    m: log-position,
    name: definite-description,
    imp-params: list(pair(binder-f(mt, a), ?a)),
    exp-params: list(binder-f(mt, a)),
    cod: a,
    body: a,
  )
}

inline stmt: type {
  stmt-f(hint, term)
}

inline stripped-stmt: type {
  stmt-f(unit, term-f(unit))
}

define get-stmt-name(s: &stmt): ?pair(&log-position, &definite-description) {
  case s {
  | Stmt-Define of {m, name} =>
    Right(Pair(m, name))
  }
}

define get-stmt-names(s: &list(stmt)): list(pair(&log-position, &definite-description)) {
  filter-some(for-each-N(s, get-stmt-name))
}

data cons-info {
| Cons-Info(
    name: definite-description,
    params: list(binder-f(hint, term)),
    tag: discriminant,
  )
}

inline stmt-f-sero<m, a>(!sm: sero(m), !s: sero(a)): sero(stmt-f(m, a)) {
  let stmt-kind-sero = base-stmt-kind-sero(definite-description-sero, binder-sero(!sm, !s), !s);
  let imp-params-sero = list-sero(pair-sero(binder-sero(!sm, !s), either-sero(unit-sero, !s)));
  let exp-params-sero = list-sero(binder-sero(!sm, !s));
  let Sero of {put := !put-a, get := !get-a} = !s;
  let Sero of {put := !put-bool, get := !get-bool} = bool-sero;
  let Sero of {put := !put-log-position, get := !get-log-position} = log-position-sero;
  let Sero of {put := !put-dd, get := !get-dd} = definite-description-sero;
  let Sero of {put := !put-sk, get := !get-sk} = stmt-kind-sero;
  let Sero of {put := !put-ip, get := !get-ip} = imp-params-sero;
  let Sero of {put := !put-ep, get := !get-ep} = exp-params-sero;
  Sero of {
    put := {
      function (k, v) {
        case v {
        | Stmt-Define of {b, sk, m, name, imp-params, exp-params, cod, body} =>
          put-int64(k, 0);
          !put-bool(k, b);
          !put-sk(k, sk);
          !put-log-position(k, m);
          !put-dd(k, name);
          !put-ip(k, imp-params);
          !put-ep(k, exp-params);
          !put-a(k, cod);
          !put-a(k, body)
        }
      }
    },
    get := {
      function (k) {
        try tag = get-int64(k);
        match tag {
        | 0 =>
          try b = !get-bool(k);
          try sk = !get-sk(k);
          try m = !get-log-position(k);
          try name = !get-dd(k);
          try ip = !get-ip(k);
          try ep = !get-ep(k);
          try cod = !get-a(k);
          try body = !get-a(k);
          Right(box {
            letbox b = b;
            letbox sk = sk;
            letbox m = m;
            letbox name = name;
            letbox ip = ip;
            letbox ep = ep;
            letbox cod = cod;
            letbox body = body;
            Stmt-Define(b, sk, m, name, ip, ep, cod, body)
          })
        | _ =>
          none
        }
      }
    },
  }
}
