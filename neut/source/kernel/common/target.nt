import {
  this.kernel.common.clang-option {Clang-Option, clang-option},
  this.language.common.base-name {base-name, main-name, zen-name},
  this.language.common.source-locator {source-locator},
}

data target-summary {
| Target-Summary(
    entry-point: source-locator,
    clang-option: clang-option,
  )
}

data main-target {
| Named(target-name: string, target-info: target-summary)
| Zen(file-path: string, option: clang-option)
}

data target {
| Main(main-target)
| Peripheral
| Peripheral-Single(file-path: text)
}

define empty-zen(path: string) -> main-target {
  Zen(path, Clang-Option{compile-option := List[], link-option := List[]})
}

define get-entry-point-name(t: &main-target) -> base-name {
  case t {
  | Named{} =>
    main-name()
  | Zen{} =>
    zen-name()
  }
}

define get-compile-option(t: &target) -> list(string) {
  case t {
  | Peripheral =>
    List[]
  | Peripheral-Single{} =>
    List[]
  | Main(c) =>
    case c {
    | Named(_, target-summary) =>
      tie Target-Summary(_, Clang-Option{compile-option}) = target-summary;
      *compile-option
    | Zen(_, Clang-Option{compile-option}) =>
      *compile-option
    }
  }
}

define get-link-option(t: &target) -> list(string) {
  case t {
  | Peripheral =>
    List[]
  | Peripheral-Single{} =>
    List[]
  | Main(c) =>
    case c {
    | Named(_, target-summary) =>
      tie Target-Summary(_, Clang-Option{link-option}) = target-summary;
      *link-option
    | Zen(_, Clang-Option{link-option}) =>
      *link-option
    }
  }
}
