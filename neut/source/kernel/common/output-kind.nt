import {
  this.app.app {app},
  this.app.error {new-error-prime},
}

data output-kind {
| Object
| LLVM
}

define output-kind-from-string(t: &string) -> app(output-kind) {
  if eq-string(t, "object") {
    Right(Object)
  } else-if eq-string(t, "llvm") {
    Right(LLVM)
  } else {
    let t = core.string.append("Invalid output kind: ", t);
    Left(new-error-prime(t))
  }
}
