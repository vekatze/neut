import {
  this.gensym.gensym {gensym-kit},
  this.kernel.common.create-global-kit {Global-Kit, global-kit},
  this.kernel.common.kit.global.module {module-kit},
}

data get-module-kit {
| _Get-Module-Kit(
    gensym-kit: &gensym-kit,
    module-kit: &module-kit,
  )
}

define make-get-module-kit(k: &global-kit): get-module-kit {
  tie Global-Kit of {gensym-kit, module-kit} = k;
  _Get-Module-Kit of {gensym-kit, module-kit}
}
