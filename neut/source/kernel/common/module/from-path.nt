import {
  core.dictionary {dictionary, from-list},
  core.list {for-each, for-each-E, for-each-EN},
  core.text-builder {append-text, make-text-builder},
  path.path,
  this.app.app {app},
  this.app.run {raise-error},
  this.ens.ens {
    E-Bool,
    access,
    access-or-default,
    empty-list,
    ens,
    ens-key,
    get-hint-N,
    to-bool-N,
    to-list-N,
    to-string,
    to-string-N,
  },
  this.kernel.common.clang-option {clang-option, make-clang-option},
  this.kernel.common.module {
    Dependency,
    Foreign,
    dependency,
    foreign,
    key-build-option,
    key-compile-option,
    key-digest,
    key-enable-preset,
    key-foreign-input,
    key-foreign-output,
    key-foreign-script,
    key-link-option,
    key-main,
    key-mirror,
    locator-name,
    target-name,
  },
  this.kernel.common.module-URL {Module-URL},
  this.kernel.common.target {Target-Summary, target-summary},
  this.kernel.common.zen-config {Zen-Config, zen-config},
  this.language.common.base-name {
    base-name,
    base-name-from-text-meta,
    is-capitalized,
    is-reserved-alias,
    text-from-base-name-N,
  },
  this.language.common.module-alias {Module-Alias, module-alias, ord-module-alias},
  this.language.common.module-digest {Module-Digest, module-digest},
  this.language.common.source-locator {Source-Locator, source-locator},
  this.logger.hint {hint},
  this.path.ensure-file-existence {ensure-directory-existence, ensure-file-existence},
  this.syntax-tree.series {extract, extract-N, series},
}

define _interpret-preset-map(s: series(pair(text, ens))): app(dictionary(locator-name, list(base-name))) {
  try items =
    for-each-E(this.syntax-tree.series.extract(s), function (p) {
      let Pair(k, v) = p;
      try Pair(_, preset-series) = this.ens.ens.to-list(v);
      try v =
        for-each-E(extract(preset-series), function (x) {
          try Pair(m, t) = to-string(x);
          letbox-T result on t, m = base-name-from-text-meta(m, t);
          let _ = m;
          let _ = t;
          result
        });
      Right(Pair(k, v))
    });
  Right(core.dictionary.from-list(core.text.ord.as-ord, items))
}

define _interpret-source-locator(e: &ens): app(source-locator) {
  try Pair(_, path-string) = to-string-N(e);
  Right(Source-Locator(*path-string))
}

define _interpret-clang-option(e: &ens): app(clang-option) {
  let m = get-hint-N(e);
  pin fallback = empty-list(m);
  try Pair(_, build-opt-ens-series) = {
    try tmp = access-or-default(key-build-option, fallback, e);
    to-list-N(tmp)
  };
  try Pair(_, compile-opt-ens-series) = {
    try tmp = access-or-default(key-compile-option, fallback, e);
    to-list-N(tmp)
  };
  try Pair(_, link-opt-ens-series) = {
    try tmp = access-or-default(key-link-option, fallback, e);
    to-list-N(tmp)
  };
  try build-options =
    for-each-EN(extract-N(build-opt-ens-series), function (p) {
      tie Pair(_, y) = p;
      try Pair(_, c) = to-string-N(y);
      Right(*c)
    });
  try compile-options =
    for-each-EN(extract-N(compile-opt-ens-series), function (p) {
      tie Pair(_, y) = p;
      try Pair(_, c) = to-string-N(y);
      Right(*c)
    });
  try link-options =
    for-each-EN(extract-N(link-opt-ens-series), function (p) {
      tie Pair(_, y) = p;
      try Pair(_, c) = to-string-N(y);
      Right(*c)
    });
  Right(make-clang-option(build-options, compile-options, link-options))
}

define _interpret-target(p: pair(hint, series(pair(text, ens)))): app(dictionary(target-name, target-summary)) {
  let Pair(_, target-dict) = p;
  try kvs =
    for-each-E(extract(target-dict), function (p) {
      let Pair(k, v) = p;
      try entry-point on v = {
        try tmp = access(key-main, v);
        _interpret-source-locator(tmp)
      };
      try clang-option on v = _interpret-clang-option(v);
      let _ = v;
      Right(Pair(k, Target-Summary of {entry-point, clang-option}))
    });
  Right(core.dictionary.from-list(core.text.ord.as-ord, kvs))
}

define _interpret-zen-config(e: &ens): app(zen-config) {
  try clang-option = _interpret-clang-option(e);
  Right(Zen-Config(clang-option))
}

define _interpret-static-files(static-file-dict: series(pair(text, ens))): app(dictionary(text, text)) {
  try kvs =
    for-each-E(extract(static-file-dict), function (kv) {
      let Pair(k, v) = kv;
      try Pair(_, tmp) = to-string(v);
      try static-file-path-text = Right(tmp);
      Right(Pair(k, static-file-path-text))
    });
  Right(from-list(core.text.ord.as-ord, kvs))
}

define _interpret-rel-file-path(e: &ens): app(&text) {
  try Pair(_, path-string) = to-string-N(e);
  Right(path-string)
}

define _interpret-dependency-dict(
  p: pair(hint, series(pair(ens-key, ens))),
): app(dictionary(module-alias, dependency)) {
  let Pair(m, dep) = p;
  pin m = m;
  try kvs =
    for-each-E(extract(dep), function (kv) {
      let Pair(Pair(_, k), ens) = kv;
      pin ens = ens;
      pin k = k;
      letbox-T bk-or-err = base-name-from-text-meta(m, k);
      try bk = bk-or-err;
      let b on bk = is-capitalized(bk);
      try _ on bk =
        if b {
          let message =
            core.text.append(
              "Module aliases cannot be capitalized, but found: ",
              text-from-base-name-N(bk),
            );
          raise-error(*m, message)
        } else {
          Right(Unit)
        };
      let b on bk = is-reserved-alias(bk);
      try _ on bk =
        if b {
          let buf = make-text-builder(64);
          let _ on buf = {
            append-text(buf, "The reserved name `");
            append-text(buf, text-from-base-name-N(bk));
            append-text(buf, "` cannot be used as an alias of a module");
          };
          raise-error(*m, core.text-builder.extract(buf))
        } else {
          Right(Unit)
        };
      try url-list = {
        try tmp = access(key-mirror, ens);
        try Pair(_, xs) = to-list-N(tmp);
        for-each-EN(extract-N(xs), function (p) {
          tie Pair(_, x) = p;
          try Pair(_, str) = to-string-N(x);
          Right(*str)
        })
      };
      try digest = {
        try tmp = access(key-digest, ens);
        try Pair(_, str) = to-string-N(tmp);
        Right(*str)
      };
      try enable-preset = {
        pin false = E-Bool(*m, False);
        match access-or-default(key-enable-preset, false, ens) {
        | Right(tmp) =>
          try Pair(_, b) = to-bool-N(tmp);
          Right(b)
        | Left(_) =>
          Right(False)
        }
      };
      let _ = ens;
      let mirror-list = for-each(url-list, Module-URL);
      let digest = Module-Digest(digest);
      Right(Pair(
        Module-Alias(bk),
        Dependency(mirror-list, digest, enable-preset),
      ))
    });
  Right(from-list(ord-module-alias, kvs))
}

define _interpret-extra-path(module-root-dir: &text, e: &ens): app(text) {
  try Pair(m, item-path-text) = to-string-N(e);
  pin k = core.text.take-end-N(item-path-text, 1);
  let is-directory-path = eq-text(k, "/");
  let path = path.path.append(module-root-dir, item-path-text);
  if is-directory-path {
    try _ on path = ensure-directory-existence(path, *m);
    Right(path)
  } else {
    try _ on path = ensure-file-existence(path, *m);
    Right(path)
  }
}

define _interpret-foreign-dict(module-root-dir: &text, e: &ens): app(foreign) {
  try Pair(_, input) = {
    try tmp = access(key-foreign-input, e);
    to-list-N(tmp)
  };
  try Pair(_, output) = {
    try tmp = access(key-foreign-output, e);
    to-list-N(tmp)
  };
  try Pair(_, script) = {
    try tmp = access(key-foreign-script, e);
    to-list-N(tmp)
  };
  try input =
    for-each-EN(extract-N(input), function (p) {
      tie Pair(_, x) = p;
      _interpret-extra-path(module-root-dir, x)
    });
  try output =
    for-each-EN(extract-N(output), function (p) {
      tie Pair(_, x) = p;
      try x = _interpret-rel-file-path(x);
      Right(*x)
    });
  try script =
    for-each-EN(extract-N(script), function (p) {
      tie Pair(_, x) = p;
      try Pair(_, x) = to-string-N(x);
      Right(*x)
    });
  Right(Foreign of {input, output, script})
}

define _interpret-antecedent(e: &ens): app(module-digest) {
  try Pair(_, t) = to-string-N(e);
  Right(Module-Digest(*t))
}
