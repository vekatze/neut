import {
  core.dictionary {dictionary},
  core.text-builder {append-text, make-text-builder},
  path.io {is-regular-file},
  path.path,
  this.app.app {app},
  this.app.run {raise-error, raise-error'},
  this.kernel.common.kit.global.antecedent {antecedent-kit},
  this.kernel.common.module {Module, get-source-dir, module},
  this.kernel.common.source {Source, get-rel-path-from-source-dir, source},
  this.language.common.module-id {module-id, text-from-module-id},
}

inline shift-map: type {
  dictionary(module-id, module)
}

data shift-kit {
| _Shift-Kit(
    antecedent-kit: &antecedent-kit,
  )
}

define make-shift-kit(k: &antecedent-kit): shift-kit {
  _Shift-Kit(k)
}

define _get-newer-source(s: &source, m: &module): app(source) {
  try rel-source-file-path = get-rel-path-from-source-dir(s);
  let new-source-file-path on rel-source-file-path = {
    pin source-dir = get-source-dir(m);
    path.path.append(source-dir, rel-source-file-path)
  };
  tie Source of {source-hint := orig-source-hint} = s;
  let b on new-source-file-path = is-regular-file(new-source-file-path);
  if b {
    Right(Source of {
      source-hint := *orig-source-hint,
      source-module := *m,
      file-path := new-source-file-path,
    })
  } else {
    let buf = make-text-builder(64);
    tie Module of {id} = m;
    let mid-text = text-from-module-id(id);
    let _ on buf = {
      pin rel-source-file-path = rel-source-file-path;
      append-text(buf, "The file `");
      append-text(buf, rel-source-file-path);
      append-text(buf, "` is missing in the module `");
      append-text(buf, mid-text);
      append-text(buf, "``");
    };
    let message = core.text-builder.extract(buf);
    case orig-source-hint {
    | Left(_) =>
      raise-error'(message)
    | Right(m) =>
      raise-error(*m, message)
    }
  }
}
