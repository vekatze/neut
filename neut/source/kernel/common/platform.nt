import {
  this.kernel.common.arch {arch, string-from-arch},
  this.kernel.common.operating-system {operating-system, string-from-operating-system},
}

data platform {
| Platform(operating-system, arch)
}

define string-from-platform(p: &platform) -> string {
  tie Platform(os, arch) = p;
  let arch-string = string-from-arch(*arch);
  let os-string = string-from-operating-system(*os);
  pin tmp = core.string.append(arch-string, "-");
  core.string.append(tmp, os-string)
}
