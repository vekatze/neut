import {
  core.dictionary {dictionary},
  this.language.common.local-locator {local-locator},
  this.language.common.strict-global-locator {strict-global-locator},
  this.logger.hint {hint},
}

alias must-update-tag {
  bool
}

data alias-info {
| Use(must-update-tag, strict-global-locator, list(pair(hint, local-locator)))
}

alias source-alias-map {
  dictionary(text, list(alias-info))
}
