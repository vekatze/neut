import {
  core.bool {all},
  core.dictionary {dictionary, to-list},
  core.int.ord,
  core.list {filter-some, for-each},
  sero.common.get {get-int64},
  sero.common.put {put-int64},
  sero.get-kit {get-kit},
  sero.instance.bool {bool-sero},
  sero.put-kit {put-kit},
  sero.sero {Sero, sero},
  this.language.common.definite-description {definite-description, definite-description-sero, local-locator-from-dd},
  this.language.common.external-name {External-Name, external-name, external-name-sero},
  this.language.common.is-const-like {is-const-like},
  this.language.raw-term.raw-term {Loc, loc, loc-sero},
  this.logger.log {get-column, get-file-path, get-line, log-position},
  this.logger.sero.log-position {log-position-sero},
}

alias line {
  int
}

alias column {
  int
}

alias col-from {
  int
}

alias col-to {
  int
}

alias def-symbol-len {
  int
}

alias col-interval {
  pair(col-from, col-to)
}

data symbol-name {
| Local(symbol-name: int, symbol-len: def-symbol-len)
| Global(definite-description, is-const-like)
| Foreign(external-name)
}

data loc-type {
| File-Loc
| Symbol-Loc(symbol-name)
}

data loc-item {
| Loc-Item(int, col-interval, loc-type, log-position)
}

alias location-tree {
  dictionary(loc, loc-item)
}

constant empty-location-tree: location-tree {
  core.dictionary.empty
}

constant ord-loc: ord(loc) {
  let Ord{compare := !cmp-int} = core.int.ord.as-ord;
  Ord{
    compare := {
      (l1, l2) => {
        tie Loc(x1, y1) = l1;
        tie Loc(x2, y2) = l2;
        match cmp-int(x1, x2) {
        | EQ =>
          cmp-int(y1, y2)
        | c =>
          c
        }
      }
    },
  }
}

define insert(lt: loc-type, p: pair(line, col-interval), m: log-position, t: location-tree) -> location-tree {
  let Pair(l, Pair(from, to)) = p;
  core.dictionary.make-insert(ord-loc)(t, Loc(l, from), Loc-Item(l, Pair(from, to), lt, m))
}

define _get-length(s: &symbol-name) -> def-symbol-len {
  case s {
  | Local(_, len) =>
    *len
  | Global(dd, _) =>
    pin tmp = local-locator-from-dd(dd);
    core.string.length(tmp)
  | Foreign(External-Name(t)) =>
    core.string.length(t)
  }
}

data found-loc {
| Found-Loc(loc-type, &log-position, &col-interval, def-symbol-len)
}

define find(loc: &loc, t: &location-tree) -> ?found-loc {
  let lookup-LE = core.dictionary.make-lookup-LE(ord-loc);
  try Pair(_, li) = lookup-LE(t, loc);
  tie Loc-Item(line, col-interval, lt, m) = li;
  tie Loc(l, c) = loc;
  tie Pair(col-from, col-to) = col-interval;
  if or(lt-int(*col-to, *c), ne-int(*line, *l)) {
    none
  } else {
    case lt {
    | File-Loc =>
      Right(Found-Loc(File-Loc, m, col-interval, sub-int(*col-from, *col-to)))
    | Symbol-Loc(sym) =>
      Right(Found-Loc(File-Loc, m, col-interval, _get-length(sym)))
    }
  }
}

define _is-sym-loc(lt: &loc-type) -> bool {
  case lt {
  | File-Loc =>
    False
  | Symbol-Loc(_) =>
    True
  }
}

define find-ref(l: &loc, t: location-tree) -> list(pair(string, pair(line, col-interval))) {
  let kvs = to-list(t);
  filter-some(for-each(kvs, (p) => {
    let Pair(Loc(line, _), Loc-Item(_, col-interval, lt, m)) = p;
    pin lt = lt;
    tie Loc(l1, c1) = l;
    let l2 on m = get-line(m);
    let c2 on m = get-column(m);
    if all[_is-sym-loc(lt), eq-int(*l1, l2), eq-int(*c1, c2)] {
      pin m = m;
      let file-path = *get-file-path(m);
      Right(Pair(file-path, Pair(line, col-interval)))
    } else {
      none
    }
  }))
}

constant symbol-name-sero: sero(symbol-name) {
  Sero{
    put := {
      (k, v) => {
        case v {
        | Local(name, def-symbol-len) =>
          put-int64(k, 0);
          put-int64(k, *name);
          put-int64(k, *def-symbol-len);
        | Global(dd, is-const-like) =>
          let Sero{put := put-dd} = definite-description-sero;
          let Sero{put := put-bool} = bool-sero;
          put-int64(k, 1);
          put-dd(k, dd);
          put-bool(k, is-const-like);
        | Foreign(ext-name) =>
          let Sero{put := put-en} = external-name-sero;
          put-int64(k, 2);
          put-en(k, ext-name);
        }
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        match tag {
        | 0 =>
          try name = get-int64(k);
          try len = get-int64(k);
          Right(lift {Local(name, len)})
        | 1 =>
          let Sero{get := get-dd} = definite-description-sero;
          let Sero{get := get-bool} = bool-sero;
          try dd = get-dd(k);
          try b = get-bool(k);
          Right(box {
            letbox dd = dd;
            letbox b = b;
            Global(dd, b)
          })
        | 2 =>
          let Sero{get := get-en} = external-name-sero;
          try ext-name = get-en(k);
          Right(box {
            letbox ext-name = ext-name;
            Foreign(ext-name)
          })
        | _ =>
          none
        }
      }
    },
  }
}

constant loc-type-sero: sero(loc-type) {
  Sero{
    put := {
      (k, v) => {
        case v {
        | File-Loc =>
          put-int64(k, 0);
        | Symbol-Loc(sym) =>
          let Sero{put := put-sym} = symbol-name-sero;
          put-int64(k, 1);
          put-sym(k, sym);
        }
      }
    },
    get := {
      (k) => {
        try tag = get-int64(k);
        match tag {
        | 0 =>
          Right(box {File-Loc})
        | 1 =>
          let Sero{get := get-sym} = symbol-name-sero;
          try sym = get-sym(k);
          Right(box {
            letbox sym = sym;
            Symbol-Loc(sym)
          })
        | _ =>
          none
        }
      }
    },
  }
}

inline dictionary-sero<k, v>(sk: sero(k), sv: sero(v)) -> sero(dictionary(k, v)) {
  let Sero{put := !put-k, get := !get-k} = sk;
  let Sero{put := !put-v, get := !get-v} = sv;
  Sero{
    put := {
      define loop(k: &put-kit, v: &dictionary(k, v)) -> unit {
        case v {
        | core.dictionary.Tip =>
          put-int64(k, 0);
        | core.dictionary.Bin(size, key, value, left, right) =>
          put-int64(k, 1);
          put-int64(k, *size);
          put-k(k, key);
          put-v(k, value);
          loop(k, left);
          loop(k, right);
        }
      }
    },
    get := {
      define loop(k: &get-kit) -> ?+dictionary(k, v) {
        try tag = get-int64(k);
        match tag {
        | 0 =>
          Right(box {core.dictionary.Tip})
        | 1 =>
          try size = get-int64(k);
          try key = get-k(k);
          try value = get-v(k);
          try left = loop(k);
          try right = loop(k);
          Right(box {
            letbox size = lift {size};
            letbox key = key;
            letbox value = value;
            letbox left = left;
            letbox right = right;
            core.dictionary.Bin(size, key, value, left, right)
          })
        | _ =>
          none
        }
      }
    },
  }
}

constant loc-item-sero: sero(loc-item) {
  let Sero{put, get} = loc-type-sero;
  let Sero{put := put-log-position, get := get-log-position} = log-position-sero;
  Sero{
    put := {
      (k, v) => {
        tie Loc-Item(l, Pair(from, to), lt, m) = v;
        put-int64(k, *l);
        put-int64(k, *from);
        put-int64(k, *to);
        put(k, lt);
        put-log-position(k, m);
      }
    },
    get := {
      (k) => {
        try l = get-int64(k);
        try from = get-int64(k);
        try to = get-int64(k);
        try lt = get(k);
        try m = get-log-position(k);
        Right(box {
          letbox l = lift {l};
          letbox from = lift {from};
          letbox to = lift {to};
          letbox lt = lt;
          letbox m = m;
          Loc-Item(l, Pair(from, to), lt, m)
        })
      }
    },
  }
}

constant location-tree-sero: sero(location-tree) {
  dictionary-sero(loc-sero, loc-item-sero)
}
