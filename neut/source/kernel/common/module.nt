import {
  core.dictionary {dictionary, to-list},
  core.list {filter, filter-some, for-each, for-each-N, is-empty},
  core.pair {first},
  core.string {drop-N, length, string-byte-length},
  core.string-builder {append-string, extract, make-string-builder},
  path.path {drop-last, take-last},
  this.app.app {app},
  this.app.run {raise-critical-prime},
  this.ens.ens {
    E-Int,
    E-List,
    E-String,
    dict-from-list,
    dict-from-list-vertical,
    ens,
    ens-key,
    ens-path,
    has-key,
    modify-E,
  },
  this.kernel.common.clang-option {Clang-Option},
  this.kernel.common.const {archive-rel-dir, cache-rel-dir, source-rel-dir},
  this.kernel.common.module-URL {Module-URL, module-URL},
  this.kernel.common.target {Named, Target-Summary, main-target, target-summary},
  this.kernel.common.zen-config {zen-config},
  this.language.common.base-name {base-name, string-from-base-name},
  this.language.common.const {ns-sep},
  this.language.common.module-alias {module-alias, string-from-module-alias},
  this.language.common.module-digest {Module-Digest, module-digest, string-from-module-digest},
  this.language.common.module-id {Library, module-id},
  this.language.common.source-locator {get-rel-path-string, string-from-source-locator},
  this.logger.hint {hint, internal-hint},
  this.syntax-tree.comment {comment},
  this.syntax-tree.series {Bracket, Comma, from-list, nub-series, series},
}

alias locator-name {
  string
}

alias preset-map {
  dictionary(locator-name, list(base-name))
}

alias alias-preset-map {
  dictionary(string, preset-map)
}

data dependency {
| Dependency(
    mirror-list: list(module-URL),
    digest: module-digest,
    preset-enabled: bool,
  )
}

data foreign {
| Foreign(
    input: list(string),
    output: list(string),
    script: list(string),
  )
}

alias target-name {
  string
}

data module {
| Module(
    id: module-id,
    source-dir: string,
    target: dictionary(target-name, target-summary),
    zen-config: zen-config,
    archive-dir: string,
    cache-dir: string,
    dependency: dictionary(module-alias, dependency),
    extra-contents: list(string),
    antecedents: list(module-digest),
    location: string,
    foreign: foreign,
    static-files: dictionary(string, string),
    inline-limit: ?int,
    preset-map: preset-map,
  )
}

data main-module {
| Main-Module(module)
}

define extract-module(m: &main-module) -> &module {
  tie Main-Module(m) = m;
  m
}

constant key-archive: &string {
  "archive"
}

constant key-cache: &string {
  "cache"
}

constant key-source: &string {
  "source"
}

constant key-target: &string {
  "target"
}

constant key-zen: &string {
  "zen"
}

constant key-main: &string {
  "main"
}

constant key-build-option: &string {
  "build-option"
}

constant key-compile-option: &string {
  "compile-option"
}

constant key-link-option: &string {
  "link-option"
}

constant key-dependency: &string {
  "dependency"
}

constant key-digest: &string {
  "digest"
}

constant key-mirror: &string {
  "mirror"
}

constant key-enable-preset: &string {
  "enable-preset"
}

constant key-extra-content: &string {
  "extra-content"
}

constant key-antecedent: &string {
  "antecedent"
}

constant key-static: &string {
  "static"
}

constant key-foreign: &string {
  "foreign"
}

constant key-foreign-input: &string {
  "input"
}

constant key-foreign-output: &string {
  "output"
}

constant key-foreign-script: &string {
  "script"
}

constant key-prefix: &string {
  "prefix"
}

constant key-inline-limit: &string {
  "inline-limit"
}

constant key-preset: &string {
  "preset"
}

define get-module-root-dir(m: &module) -> string {
  tie Module{location} = m;
  drop-last(location)
}

define get-source-dir(m: &module) -> string {
  tie Module{source-dir} = m;
  pin tmp = get-module-root-dir(m);
  path.path.append(tmp, source-dir)
}

define get-archive-dir(m: &module) -> string {
  tie Module{archive-dir} = m;
  pin tmp = get-module-root-dir(m);
  path.path.append(tmp, archive-dir)
}

define _values<k, v>(d: &dictionary(k, v)) -> list(&v) {
  case d {
  | core.dictionary.Tip =>
    Nil
  | core.dictionary.Bin(_, _, v, d1, d2) =>
    let xs = _values(d1);
    let ys = _values(d2);
    core.list.append(xs, Cons(v, ys))
  }
}

define get-target-path-list(m: &module) -> list(string) {
  tie Module{source-dir, target} = m;
  for-each(_values(target), (v) => {
    tie Target-Summary{entry-point} = v;
    let tmp = string-from-source-locator(entry-point);
    let result on tmp = path.path.append(source-dir, tmp);
    let _ = tmp;
    result
  })
}

define _lookup-string-dict<v>(d: &dictionary(string, v), k: &string) -> ?&v {
  let lookup = core.dictionary.make-lookup(core.string.ord.as-ord);
  lookup(d, k)
}

define get-target-path(m: &module, target-key: &string) -> ?string {
  tie Module{source-dir, target} = m;
  try v = _lookup-string-dict(target, target-key);
  tie Target-Summary{entry-point} = v;
  pin tmp = string-from-source-locator(entry-point);
  Right(path.path.append(source-dir, tmp))
}

define get-extra-contents(m: &module) -> &list(string) {
  tie Module{extra-contents} = m;
  extra-contents
}

constant _m: hint {
  internal-hint
}

define _series-from-list<a>(xs: list(a)) -> series(a) {
  from-list(Bracket, Comma, xs)
}

define _get-target-info(m: &module) -> pair(ens-key, ens) {
  tie Module{target} = m;
  let tmp =
    for-each(to-list(*target), (p) => {
      let Pair(target-name, target-summary) = p;
      let Target-Summary(entry-point, Clang-Option(compile-option, link-option)) = target-summary;
      let compile-option =
        for-each(compile-option, (x) => {
          E-String(_m, x)
        });
      let b on compile-option = is-empty(compile-option);
      let compile-option =
        if b {
          List[]
        } else {
          List[Pair(Pair(_m, *key-compile-option), E-List(_m, _series-from-list(compile-option)))]
        };
      let link-option =
        for-each(link-option, (x) => {
          E-String(_m, x)
        });
      let b on link-option = is-empty(link-option);
      let link-option =
        if b {
          List[]
        } else {
          List[Pair(Pair(_m, *key-link-option), E-List(_m, _series-from-list(link-option)))]
        };
      let items = core.list.append(compile-option, link-option);
      let items = Cons(Pair(Pair(_m, *key-main), E-String(_m, get-rel-path-string(entry-point))), items);
      Pair(Pair(_m, target-name), dict-from-list-vertical(_m, items))
    });
  Pair(Pair(_m, *key-target), dict-from-list-vertical(_m, tmp))
}

define _get-source-dir-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{source-dir} = m;
  if eq-string(source-dir, source-rel-dir) {
    none
  } else {
    Right(Pair(Pair(_m, *key-source), ens-path(_m, *source-dir)))
  }
}

define _get-cache-dir-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{cache-dir} = m;
  if eq-string(cache-dir, cache-rel-dir) {
    none
  } else {
    Right(Pair(Pair(_m, *key-cache), ens-path(_m, *cache-dir)))
  }
}

define _get-archive-dir-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{archive-dir} = m;
  if eq-string(archive-dir, archive-rel-dir) {
    none
  } else {
    Right(Pair(Pair(_m, *key-archive), ens-path(_m, *archive-dir)))
  }
}

define _get-extra-content-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{extra-contents} = m;
  let extra-content-list =
    for-each-N(extra-contents, (v) => {
      E-String(_m, *v)
    });
  let b on extra-content-list = is-empty(extra-content-list);
  if b {
    none
  } else {
    Right(Pair(Pair(_m, *key-extra-content), E-List(_m, _series-from-list(extra-content-list))))
  }
}

define _get-foreign-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{foreign := Foreign{input, output, script}} = m;
  let input-list =
    for-each-N(input, (x) => {
      E-String(_m, *x)
    });
  let output-list =
    for-each-N(output, (x) => {
      E-String(_m, *x)
    });
  let command-list =
    for-each-N(script, (x) => {
      E-String(_m, *x)
    });
  if and(is-empty(input), is-empty(script)) {
    none
  } else {
    Right(Pair(
      Pair(_m, *key-foreign),
      dict-from-list-vertical(_m, List[
        Pair(Pair(_m, *key-foreign-input), E-List(_m, _series-from-list(input-list))),
        Pair(Pair(_m, *key-foreign-output), E-List(_m, _series-from-list(output-list))),
        Pair(Pair(_m, *key-foreign-script), E-List(_m, _series-from-list(command-list))),
      ]),
    ))
  }
}

define _get-inline-limit-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{inline-limit} = m;
  try inline-limit = *inline-limit;
  Right(Pair(Pair(_m, *key-inline-limit), E-Int(_m, inline-limit)))
}

define _get-preset-map-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{preset-map} = m;
  if eq-int(core.dictionary.size(preset-map), 0) {
    none
  } else {
    let tmp =
      for-each(to-list(*preset-map), (x) => {
        let Pair(k, vs) = x;
        let vs =
          for-each(vs, (bn) => {
            E-String(_m, string-from-base-name(bn))
          });
        Pair(Pair(_m, k), E-List(_m, _series-from-list(vs)))
      });
    Right(Pair(Pair(_m, *key-preset), dict-from-list(_m, tmp)))
  }
}

define _get-antecedent-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{antecedents} = m;
  if is-empty(antecedents) {
    none
  } else {
    let antecedent-list =
      for-each-N(antecedents, (x) => {
        E-String(_m, *string-from-module-digest(x))
      });
    Right(Pair(Pair(_m, *key-antecedent), E-List(_m, _series-from-list(antecedent-list))))
  }
}

define _get-dependency-info(m: &module) -> ?pair(ens-key, ens) {
  tie Module{dependency} = m;
  if eq-int(core.dictionary.size(dependency), 0) {
    none
  } else {
    let tmp =
      for-each(to-list(*dependency), (p) => {
        let Pair(k, Dependency{mirror-list, digest := Module-Digest(d)}) = p;
        let url-ens-list =
          for-each(mirror-list, (x) => {
            let Module-URL(x) = x;
            E-String(_m, x)
          });
        let digest-ens = E-String(_m, d);
        let mirror-ens = E-List(_m, _series-from-list(url-ens-list));
        Pair(
          Pair(_m, string-from-module-alias(k)),
          dict-from-list-vertical(
            _m,
            List[
              Pair(Pair(_m, *key-digest), digest-ens),
              Pair(Pair(_m, *key-mirror), mirror-ens),
            ],
          ),
        )
      });
    Right(Pair(Pair(_m, *key-dependency), dict-from-list-vertical(_m, tmp)))
  }
}

define to-default-ens(m: &module) -> ens {
  dict-from-list(
    _m,
    filter-some(List[
      Right(_get-target-info(m)),
      _get-source-dir-info(m),
      _get-cache-dir-info(m),
      _get-archive-dir-info(m),
      _get-extra-content-info(m),
      _get-foreign-info(m),
      _get-inline-limit-info(m),
      _get-preset-map-info(m),
      _get-antecedent-info(m),
      _get-dependency-info(m),
    ]),
  )
}

define get-module-id-from-module-path(module-file-path: &string) -> module-id {
  pin tmp = drop-last(module-file-path);
  let dir-name = take-last(tmp);
  Library(Module-Digest(dir-name))
}

define get-target(m: &module, target-name: &string) -> ?main-target {
  tie Module{target} = m;
  try target = _lookup-string-dict(target, target-name);
  Right(Named(*target-name, *target))
}

define stylize(eq: &eq(pair(comment, ens)), e: ens) -> app(ens) {
  let has-dependency-key on e = has-key(key-dependency, e);
  if has-dependency-key {
    try tmp =
      modify-E(e, key-dependency, (foo) => {
        modify-E(foo, key-mirror, (mirrors) => {
          try Pair(m-dep, mirror-list) = this.ens.ens.to-list(mirrors);
          let mirror-list = nub-series(eq, mirror-list);
          Right(E-List(m-dep, mirror-list))
        })
      });
    Right(tmp)
  } else {
    Right(e)
  }
}

define get-alias-list-with-enabled-presets(m: &module) -> list(module-alias) {
  tie Module{dependency} = m;
  for-each(
    filter(to-list(*dependency), (p) => {
      tie Pair(_, v) = p;
      tie Dependency{preset-enabled} = v;
      *preset-enabled
    }),
    exact first,
  )
}

alias preset-summary {
  list(pair(string, list(base-name)))
}

define get-preset-summary(preset-map: preset-map, module-name: &string) -> preset-summary {
  let preset-list = to-list(preset-map);
  for-each(preset-list, (p) => {
    let Pair(loc, lls) = p;
    let tmp = core.string.append(module-name, ns-sep);
    let tmp2 on tmp, loc = core.string.append(tmp, loc);
    let _ = tmp;
    let _ = loc;
    Pair(tmp2, lls)
  })
}

define _strip-prefix(haystack: &string, prefix: &string) -> ?string {
  let b1 = core.string.eq.eq-prefix(haystack, prefix);
  let b2 = ge-int(string-byte-length(haystack), string-byte-length(prefix));
  if and(b1, b2) {
    Right(drop-N(haystack, length(prefix)))
  } else {
    none
  }
}

define get-rel-path-from-source-dir(m: &module, path: &string) -> app(string) {
  let source-dir = get-source-dir(m);
  let tmp on source-dir = _strip-prefix(source-dir, path);
  let _ = source-dir;
  match tmp {
  | Right(path) =>
    Right(path)
  | Left(_) =>
    let buf = make-string-builder(64);
    let _ on buf = {
      pin source-dir = get-source-dir(m);
      append-string(buf, "The file\n  ");
      append-string(buf, path);
      append-string(buf, "\nis not an element of\n  ");
      append-string(buf, source-dir);
    };
    raise-critical-prime(extract(buf))
  }
}

define zen() -> unit {
  pin result = _strip-prefix("abcd", "");
  vet::(result);
  pin result = _strip-prefix("abcd", "a");
  vet::(result);
  pin result = _strip-prefix("abcd", "ab");
  vet::(result);
  pin result = _strip-prefix("abcd", "bc");
  vet::(result);
  pin result = _strip-prefix("abcd", "cd");
  vet::(result);
  pin result = _strip-prefix("abcd", "abc");
  vet::(result);
  pin result = _strip-prefix("abcd", "bcd");
  vet::(result);
  pin result = _strip-prefix("abcd", "abcd");
  vet::(result);
}
