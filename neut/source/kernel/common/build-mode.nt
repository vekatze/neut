import {
  this.app.app {app},
  this.app.error {new-error-prime},
}

data build-mode {
| Develop
| Release
}

define string-from-build-mode(bm: build-mode) -> &string {
  match bm {
  | Develop =>
    "develop"
  | Release =>
    "release"
  }
}

define build-mode-from-string(t: &string) -> app(build-mode) {
  if eq-string(t, "develop") {
    Right(Develop)
  } else-if eq-string(t, "release") {
    Right(Release)
  } else {
    let t = core.string.append("No such build mode exists: ", t);
    Left(new-error-prime(t))
  }
}
