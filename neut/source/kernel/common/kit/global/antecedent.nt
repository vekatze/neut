import {
  core.cell {borrow, extract, make-cell, mutate},
  core.dictionary {dictionary, empty, make-insert-with, make-lookup, to-list},
  core.list {fold-left},
  core.magic {cast},
  this.kernel.common.module {Module, module},
  this.language.common.module-id {module-id, module-id-ord},
}

alias rev-map {
  dictionary(module-id, list(module-id))
}

data antecedent-kit {
| _Antecedent-Kit(
    map-cell: cell(dictionary(module-id, module)),
    rev-map-cell: cell(dictionary(module-id, list(module-id))),
  )
}

define make-antecedent-kit() -> antecedent-kit {
  let map-cell = make-cell(box {empty});
  let rev-map-cell = make-cell(box {empty});
  _Antecedent-Kit{map-cell, rev-map-cell}
}

define lookup-module(k: &antecedent-kit, x: &module-id) -> ?module {
  tie _Antecedent-Kit{map-cell} = k;
  let lookup = make-lookup(module-id-ord);
  borrow(map-cell, (dict) => {
    match lookup(dict, x) {
    | Left(_) =>
      box {none}
    | Right(v) =>
      box v {Right(v)}
    }
  })
}

inline _dictionary-meta-in<k, v>(dict: +dictionary(k, v)) -> dictionary(+k, +v) {
  cast<_, _>(dict)
}

define _rev-insert(mp: +rev-map, v: +module, k: +module-id) -> +rev-map {
  box {
    letbox mp = mp;
    letbox k = k;
    letbox v = v;
    let Module{id} = v;
    let insert = make-insert-with(module-id-ord, exact core.list.append);
    insert(mp, id, List[k])
  }
}

define set(k: &antecedent-kit, !mp: +dictionary(module-id, module)) -> unit {
  tie _Antecedent-Kit{map-cell, rev-map-cell} = k;
  mutate(map-cell, (_) => {
    mp
  });
  mutate(rev-map-cell, (dict) => {
    let other-mp = to-list(_dictionary-meta-in(mp));
    fold-left(dict, other-mp, (d, p) => {
      let Pair(mid, m) = p;
      _rev-insert(d, m, mid)
    })
  });
}

define get-reverse-map(k: antecedent-kit) -> +rev-map {
  let _Antecedent-Kit{rev-map-cell} = k;
  extract(rev-map-cell)
}
