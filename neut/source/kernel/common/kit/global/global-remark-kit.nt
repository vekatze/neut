import {
  core.cell {cell, make-cell, mutate},
  this.logger.log {log},
}

data global-remark-kit {
| _Global-Remark-Kit(remark-list: cell(list(log)))
}

define make-global-remark-kit() -> global-remark-kit {
  let ref = make-cell(box {Nil});
  _Global-Remark-Kit(ref)
}

define insert-remark(k: &global-remark-kit, items: +list(log)) -> unit {
  tie _Global-Remark-Kit(ref) = k;
  mutate(ref, (xs) => {
    box {
      letbox xs = xs;
      letbox items = items;
      core.list.append(xs, items)
    }
  })
}

define clone-logs(k: &global-remark-kit) -> list(log) {
  tie _Global-Remark-Kit(ref) = k;
  core.cell.clone(ref)
}

define extract-logs(k: global-remark-kit) -> +list(log) {
  let _Global-Remark-Kit(ref) = k;
  core.cell.extract(ref)
}
