import {
  core.dictionary {dictionary},
  core.string.builder {append-string, extract, make-string-builder},
  core.sync.cell {cell, make-cell},
  this.app.app {app},
  this.app.run {raise-critical-prime},
  this.kernel.common.artifact {artifact-time},
}

data artifact-kit {
| _Artifact-Kit(
    artifact-map-ref: cell(dictionary(string, artifact-time)),
  )
}

define make-artifact-kit() -> artifact-kit {
  let artifact-map-ref = make-cell(box {core.dictionary.empty});
  _Artifact-Kit{artifact-map-ref}
}

define insert(k: &artifact-kit, path: string, t: artifact-time) -> unit {
  tie _Artifact-Kit(ref) = k;
  core.sync.cell.mutate(ref, (dict) => {
    box {
      letbox dict = dict;
      letbox path = lift {path};
      letbox t = lift {t};
      pin ord = core.string.ord.as-ord;
      core.dictionary.insert(ord, dict, path, t)
    }
  })
}

define lookup(k: &artifact-kit, path: &string) -> app(artifact-time) {
  tie _Artifact-Kit(ref) = k;
  let tmp: ?artifact-time =
    core.sync.cell.borrow(ref, (dict) => {
      pin ord = core.string.ord.as-ord;
      match core.dictionary.lookup(ord, dict, path) {
      | Left(_) =>
        box {none}
      | Right(v) =>
        box v {Right(v)}
      }
    });
  match tmp {
  | Left(_) =>
    let buf = make-string-builder(64);
    let _ on buf = {
      append-string(buf, "No artifact time is registered for the source: ");
      append-string(buf, path);
    };
    raise-critical-prime(extract(buf))
  | Right(v) =>
    Right(v)
  }
}
