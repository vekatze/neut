import {
  core.cell {make-cell, mutate},
  this.app.run {run},
  this.kernel.common.build-mode {Develop, build-mode},
  this.kernel.common.module {Main-Module, main-module},
  this.kernel.common.module.from-path {from-current-path, from-file-path},
  this.logger.logger-kit {logger-kit},
}

data env-kit {
| _Env-Kit(
    build-mode-cell: cell(build-mode),
    enable-silent-mode: bool,
    main-module: main-module,
  )
}

define get-main-module(k: &env-kit): &main-module {
  tie _Env-Kit of {main-module} = k;
  main-module
}

define get-silent-mode(k: &env-kit): &bool {
  tie _Env-Kit of {enable-silent-mode} = k;
  enable-silent-mode
}

define make-env-kit(k: &logger-kit, enable-silent-mode: bool, module-file-path: ?text): env-kit {
  let build-mode-cell = make-cell(box {Develop});
  run(k, {
    try m =
      match module-file-path {
      | Left(_) =>
        from-current-path()
      | Right(path) =>
        pin path = path;
        from-file-path(path)
      };
    let main-module = Main-Module(m);
    Right(_Env-Kit of {build-mode-cell, enable-silent-mode, main-module})
  })
}

define set-build-mode(k: &env-kit, bm: build-mode): unit {
  tie _Env-Kit of {build-mode-cell} = k;
  mutate(build-mode-cell, function (_) {
    quote {bm}
  })
}
