import {
  core.cell {borrow, make-cell, mutate},
  this.app.app {app},
  this.app.run {raise-error-prime, run},
  this.kernel.common.build-mode {Develop, build-mode},
  this.kernel.common.module {
    Main-Module,
    Module,
    _lookup-string-dict,
    extract-module,
    get-rel-path-from-source-dir,
    main-module,
  },
  this.kernel.common.module.from-path {from-current-path, from-file-path},
  this.kernel.common.target {Named, Target-Summary, Zen, main-target},
  this.language.common.base-name {base-name, main-name, zen-name},
  this.language.common.definite-description {definite-description, new-dd},
  this.language.common.local-locator {make-local-locator},
  this.language.common.module-id {Main},
  this.language.common.source-locator {Source-Locator, string-from-source-locator},
  this.language.common.strict-global-locator {Strict-Global-Locator},
  this.logger.logger-kit {logger-kit},
  this.path.util {remove-extension},
}

data env-kit {
| _Env-Kit(
    build-mode-cell: cell(build-mode),
    enable-silent-mode: bool,
    main-module: main-module,
  )
}

define get-main-module(k: &env-kit) -> &main-module {
  tie _Env-Kit {main-module} = k;
  main-module
}

define get-silent-mode(k: &env-kit) -> &bool {
  tie _Env-Kit {enable-silent-mode} = k;
  enable-silent-mode
}

define make-env-kit(k: &logger-kit, enable-silent-mode: bool, module-file-path: ?string) -> env-kit {
  let build-mode-cell = make-cell(box {Develop});
  run(k, {
    try m =
      match module-file-path {
      | Left(_) =>
        from-current-path()
      | Right(path) =>
        pin path = path;
        from-file-path(path)
      };
    let main-module = Main-Module(m);
    Right(_Env-Kit {build-mode-cell, enable-silent-mode, main-module})
  })
}

define set-build-mode(k: &env-kit, bm: build-mode) -> unit {
  tie _Env-Kit {build-mode-cell} = k;
  mutate(build-mode-cell, (_) => {
    lift {bm}
  })
}

define get-build-mode(k: &env-kit) -> build-mode {
  tie _Env-Kit {build-mode-cell} = k;
  borrow(build-mode-cell, (bm) => {
    box bm {bm}
  })
}

define _rel-path-to-dd(rel-path: &string, bn: base-name) -> app(definite-description) {
  try tmp = remove-extension(rel-path);
  pin sgl = Strict-Global-Locator {module-id := Main, source-locator := Source-Locator(tmp)};
  let ll = make-local-locator(bn);
  Right(new-dd(sgl, ll))
}

define get-main-definite-description(k: &env-kit, t: &main-target) -> app(definite-description) {
  tie _Env-Kit {main-module} = k;
  case t {
  | Named(target, _) =>
    tie Module {target := target-dict} = extract-module(main-module);
    match _lookup-string-dict(target-dict, target) {
    | Left(_) =>
      let message = core.string.append("No such target is defined: ", target);
      raise-error-prime(message)
    | Right(target-summary) =>
      tie Target-Summary {entry-point} = target-summary;
      pin source-locator-string = string-from-source-locator(entry-point);
      _rel-path-to-dd(source-locator-string, main-name())
    }
  | Zen(path, _) =>
    try rel-path = get-rel-path-from-source-dir(extract-module(main-module), path);
    pin rel-path = rel-path;
    _rel-path-to-dd(rel-path, zen-name())
  }
}
