import {
  core.cell {borrow, extract, make-cell, mutate},
  core.text-builder {append-text, make-text-builder},
  path.path {split-extension},
  this.app.app {app},
  this.app.run {raise-error', run},
  this.kernel.common.build-mode {Develop, build-mode},
  this.kernel.common.const {source-file-extension},
  this.kernel.common.module {Main-Module, extract-module, get-rel-path-from-source-dir, main-module},
  this.kernel.common.module.from-path {from-current-path, from-file-path},
  this.kernel.common.target {Named, Zen, main-target},
  this.language.common.definite-description {definite-description},
  this.logger.logger-kit {logger-kit},
}

data env-kit {
| _Env-Kit(
    build-mode-cell: cell(build-mode),
    enable-silent-mode: bool,
    main-module: main-module,
  )
}

define get-main-module(k: &env-kit): &main-module {
  tie _Env-Kit of {main-module} = k;
  main-module
}

define get-silent-mode(k: &env-kit): &bool {
  tie _Env-Kit of {enable-silent-mode} = k;
  enable-silent-mode
}

define make-env-kit(k: &logger-kit, enable-silent-mode: bool, module-file-path: ?text): env-kit {
  let build-mode-cell = make-cell(box {Develop});
  run(k, {
    try m =
      match module-file-path {
      | Left(_) =>
        from-current-path()
      | Right(path) =>
        pin path = path;
        from-file-path(path)
      };
    let main-module = Main-Module(m);
    Right(_Env-Kit of {build-mode-cell, enable-silent-mode, main-module})
  })
}

define set-build-mode(k: &env-kit, bm: build-mode): unit {
  tie _Env-Kit of {build-mode-cell} = k;
  mutate(build-mode-cell, function (_) {
    quote {bm}
  })
}

define get-build-mode(k: &env-kit): build-mode {
  tie _Env-Kit of {build-mode-cell} = k;
  borrow(build-mode-cell, function (bm) {
    box bm {bm}
  })
}

define _remove-extension(path: &text): app(text) {
  let Pair(a, b) = split-extension(path);
  let has-valid-extension on b = eq-text(b, source-file-extension);
  let _ = b;
  if has-valid-extension {
    Right(a)
  } else {
    let buf = make-text-builder(64);
    let _ on buf = {
      append-text(buf, "The file extension in `");
      append-text(buf, path);
      append-text(buf, "` is invalid")
    };
    raise-error'(core.text-builder.extract(buf))
  }
}
