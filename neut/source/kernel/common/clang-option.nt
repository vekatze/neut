data clang-option {
| Clang-Option(
    compile-option: list(string),
    link-option: list(string),
  )
}

define make-clang-option(
  !build-option: list(string),
  compile-option: list(string),
  link-option: list(string),
) -> clang-option {
  let compile-option = core.list.append(build-option, compile-option);
  let link-option = core.list.append(build-option, link-option);
  Clang-Option {compile-option, link-option}
}

constant empty-clang-option: clang-option {
  Clang-Option {compile-option := Nil, link-option := Nil}
}
