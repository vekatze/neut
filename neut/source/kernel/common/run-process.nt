import {
  core.c-int {eq-c-int},
  core.debug {vet-doc},
  core.doc.show {show-doc},
  core.list {for-each},
  core.process {Exited, Process-Result, Process-Spec, process-spec, spawn},
  core.string {intercalate, split},
  core.string-builder {append-int64-UTF8, append-string, make-string-builder},
  core.system {get-error-message},
  this.color.color-kit {make-color-kit},
  this.logger.logger-kit {logger-kit, make-logger-kit},
  this.logger.print {report},
}

data run-process-kit {
| _Run-Process-Kit(
    logger-kit: &logger-kit,
  )
}

define make-run-process-kit(logger-kit: &logger-kit) -> run-process-kit {
  _Run-Process-Kit(logger-kit)
}

define get-logger-kit(k: &run-process-kit) -> &logger-kit {
  tie _Run-Process-Kit{logger-kit} = k;
  *logger-kit
}

data command-error {
| Command-Error(
    spec: process-spec,
    exit-code: int,
    err-str: string,
  )
}

data process-error {
| Command-Execution-Error(command-error)
| Setup-Error(string)
}

define _indent(t: &string) -> string {
  let ts = split(t, "\n");
  let ts =
    for-each(ts, (t) => {
      pin t = t;
      core.string.append("  ", t)
    });
  intercalate(ts, *"\n")
}

define _string-from-process-error(pe: process-error) -> string {
  match pe {
  | Command-Execution-Error(Command-Error(cmd-spec, exit-code, err-str)) =>
    let Process-Spec{process} = cmd-spec;
    let buf = make-string-builder(64);
    pin err-str = err-str;
    pin process = process;
    let _ on buf = {
      append-string(buf, "The child process `");
      append-string(buf, process);
      append-string(buf, "` failed with the following message (exit-code = ");
      append-int64-UTF8(buf, exit-code);
      append-string(buf, "):\n");
      pin v = _indent(err-str);
      append-string(buf, v);
    };
    core.string-builder.extract(buf)
  | Setup-Error(t) =>
    t
  }
}

define _report-command(k: &run-process-kit, s: &process-spec) -> unit {
  tie _Run-Process-Kit{logger-kit} = k;
  let message = {
    pin tmp = vet-doc::(s);
    pin tmp = show-doc(tmp, 65535);
    core.string.append("Executing: ", tmp)
  };
  report(*logger-kit, message);
}

define run-process(k: &run-process-kit, s: process-spec) -> either(string, string) {
  let _ on s = _report-command(k, s);
  match spawn(s, 1024, 1024) {
  | Left(e) =>
    Left(get-error-message(e))
  | Right(Process-Result{status, stdout-string, stderr-string}) =>
    match status {
    | Exited(status-code) =>
      if eq-c-int(status-code, 0) {
        Right(stdout-string)
      } else {
        Left(stderr-string)
      }
    | _ =>
      Left(stderr-string)
    }
  }
}

define run-simple-process(k: &run-process-kit, proc-name: string, args: list(string)) -> either(string, string) {
  let spec = Process-Spec(proc-name, args, none, *"");
  run-process(k, spec)
}

define zen() -> unit {
  pin lk = make-logger-kit(make-color-kit(True, True), True);
  pin k = make-run-process-kit(lk);
  pin s = Process-Spec(*"foo", List[*"bar", *"buz"], none, *"some-input");
  _report-command(k, s);
  pin result = run-simple-process(k, *"ls", Nil);
  vet::(result);
  pin result = run-process(k, Process-Spec(*"ls", Nil, Right(*"/etc"), *""));
  vet::(result);
}
