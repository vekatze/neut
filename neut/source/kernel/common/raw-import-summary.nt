import {
  sero.instance.list {list-sero},
  sero.instance.pair {pair-sero},
  sero.instance.string {string-sero},
  sero.sero {Sero, sero},
  this.language.raw-term.raw-stmt {raw-import},
  this.language.raw-term.raw-term {loc, loc-sero},
}

data raw-import-summary {
| Raw-Import-Summary(
    items: list(pair(string, list(string))),
    loc: loc,
  )
}

define from-raw-import(ri: raw-import) -> raw-import-summary {
  match ri {}
}

constant raw-import-summary-sero: sero(raw-import-summary) {
  let Sero{put := put-items, get := get-items} = list-sero(pair-sero(string-sero, list-sero(string-sero)));
  let Sero{put := put-loc, get := get-loc} = loc-sero;
  Sero{
    put := {
      (k, v) => {
        tie Raw-Import-Summary(items, loc) = v;
        put-items(k, items);
        put-loc(k, loc);
      }
    },
    get := {
      (k) => {
        try items = get-items(k);
        try loc = get-loc(k);
        Right(box {
          letbox items = items;
          letbox loc = loc;
          Raw-Import-Summary(items, loc)
        })
      }
    },
  }
}
