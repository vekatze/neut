import {
  core.string-builder {append-string, make-string-builder},
  path.path {split-extension},
  this.app.app {app},
  this.app.run {raise-error-prime},
  this.kernel.common.const {source-file-extension},
}

define remove-extension(path: &string) -> app(string) {
  let Pair(a, b) = split-extension(path);
  let has-valid-extension on b = eq-string(b, source-file-extension);
  let _ = b;
  if has-valid-extension {
    Right(a)
  } else {
    let buf = make-string-builder(64);
    let _ on buf = {
      append-string(buf, "The file extension in `");
      append-string(buf, path);
      append-string(buf, "` is invalid")
    };
    raise-error-prime(core.string-builder.extract(buf))
  }
}
