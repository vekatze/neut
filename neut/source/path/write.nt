import {
  core.binary {binary},
  core.binary.io,
  core.file.access-mode {Write},
  core.file.descriptor {close, open},
  core.file.mode {default-file-mode},
  core.string {to-binary},
  core.system {system},
}

define _write-binary-to-path(path: &string, content: &binary) -> system(unit) {
  let r = Right(Unit); // fixme (use destpass)
  try _ = r;
  try fd = open(path, Write)[create := Right(default-file-mode), truncate := True];
  try _ = core.binary.io.write(fd, content);
  try _ = close(fd);
  Right(Unit)
}

define write-string(path: &string, content: &string) -> system(unit) {
  let r = Right(Unit); // fixme
  try _ = r;
  let content-binary = to-binary(content);
  _write-binary-to-path(path, content-binary)
}
