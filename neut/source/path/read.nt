import {
  core.binary {binary},
  core.binary.io,
  core.file {close, open},
  core.file.descriptor {stdin},
  core.file.flag {R},
  core.file.mode {default-file-mode},
  core.system {get-error-message, system},
  this.app.app {app},
  this.app.error {new-error-prime},
  this.path.ensure-file-existence {ensure-file-existence-prime},
}

define is-stdin(path: &string) -> bool {
  eq-string(path, "-")
}

define _read-binary-from-stdin() -> system(binary) {
  let r = Right(Unit); // fixme
  try _ = r;
  core.binary.io.read(stdin, 1024)
}

define _read-binary-from-path(path: &string) -> system(binary) {
  let r = Right(Unit); // fixme
  try _ = r;
  try fd = open(path, List[R], default-file-mode);
  try content = core.binary.io.read(fd, 4096);
  try _ = close(fd);
  Right(content)
}

define read-string-from-path(path: &string) -> app(string) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ = ensure-file-existence-prime(path);
  match _read-binary-from-path(path) {
  | Left(sys-err) =>
    Left(new-error-prime(get-error-message(sys-err)))
  | Right(content-binary) =>
    Right(magic cast(binary, string, content-binary))
  }
}

define zen() -> unit {
  pin x = read-string-from-path("/etc/bashrc");
  vet::(x);
}
