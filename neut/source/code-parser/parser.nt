import {
  core.vector {push-back, to-list},
  this.syntax-tree.comment {Comment-Item, Inline-Comment, Line-Comment, comment, comment-item, comment-type},
  zonk.parse {any-rune, chunk, many, optional, parsed, zonk},
  zonk.zonk-kit {zonk-kit},
}

alias parser-kit {
  zonk-kit(string)
}

alias parser(a) {
  zonk(string, a)
}

define is-non-symbol-char(r: rune) -> bool {
  match r {
  | `=` =>
    True
  | `(` =>
    True
  | `)` =>
    True
  | ` ` =>
    True
  | `\`` =>
    True
  | `"` =>
    True
  | `\n` =>
    True
  | `\t` =>
    True
  | `:` =>
    True
  | `;` =>
    True
  | `,` =>
    True
  | `<` =>
    True
  | `>` =>
    True
  | `[` =>
    True
  | `]` =>
    True
  | `{` =>
    True
  | `}` =>
    True
  | `/` =>
    True
  | `*` =>
    True
  | `|` =>
    True
  | `&` =>
    True
  | `?` =>
    True
  | _ =>
    False
  }
}

define is-symbol-char(r: rune) -> bool {
  not(is-non-symbol-char(r))
}

define skip-space(k: &parser-kit) -> parsed(unit) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ =
    zonk.parse.take-while((r) => {
      match r {
      | ` ` =>
        True
      | `\n` =>
        True
      | _ =>
        False
      }
    })(k);
  Right(Unit)
}

define skip-space-without-newline(k: &parser-kit) -> parsed(unit) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ =
    zonk.parse.take-while((r) => {
      eq-rune(r, ` `)
    })(k);
  Right(Unit)
}

define parse-comment-item(k: &parser-kit, comment-type: comment-type) -> parsed(comment-item) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ = chunk("//")(k);
  try comment-string =
    zonk.parse.take-while((r) => {
      ne-rune(r, `\n`)
    })(k);
  Right(Comment-Item{comment-string, comment-type})
}

define parse-line-comment(k: &parser-kit) -> parsed(comment-item) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ = skip-space(k);
  parse-comment-item(k, Line-Comment)
}

define space-consumer(k: &parser-kit) -> parsed(comment) {
  let r = Right(Unit); // fixme
  try _ = r;
  try _ = skip-space-without-newline(k);
  try maybe-inline-comment =
    optional((k) => {
      parse-comment-item(k, Inline-Comment)
    })(k);
  try _ = skip-space(k);
  try line-comments =
    many((k) => {
      try c = parse-line-comment(k);
      try _ = skip-space(k);
      Right(c)
    })(k);
  match maybe-inline-comment {
  | Left(_) =>
    Right(line-comments)
  | Right(ic) =>
    Right(Cons(ic, line-comments))
  }
}

inline lexeme<a>(k: &parser-kit, p: parser(a)) -> parsed(pair(a, comment)) {
  let r = Right(Unit); // fixme
  try _ = r;
  try v = p(k);
  try c = space-consumer(k);
  Right(Pair(v, c))
}

define delimiter(k: &parser-kit, expected: &string) -> parsed(comment) {
  let r = Right(Unit); // fixme
  try _ = r;
  try Pair(_, c) =
    lexeme(k, (k) => {
      try _ = chunk(expected)(k);
      Right(Unit)
    });
  Right(c)
}

define symbol(k: &parser-kit) -> parsed(pair(string, comment)) {
  let r = Right(Unit); // fixme
  try _ = r;
  lexeme(k, (k) => {
    zonk.parse.take-while-1(is-symbol-char)(k)
  })
}

define symbol-prime(k: &parser-kit) -> parsed(pair(string, comment)) {
  let r = Right(Unit); // fixme
  try _ = r;
  lexeme(k, (k) => {
    zonk.parse.take-while(is-symbol-char)(k)
  })
}

define _string-inner(k: &parser-kit, cs: vector(rune)) -> parsed(string) {
  let r = Right(Unit); // fixme
  try _ = r;
  try v = any-rune(k);
  match v {
  | `\\` =>
    try w = any-rune(k);
    _string-inner(k, push-back(push-back(cs, `\\`), w))
  | `"` =>
    let xs = to-list(cs);
    let result on xs = core.string.pack(xs);
    let _ = xs;
    Right(result)
  | v =>
    _string-inner(k, push-back(cs, v))
  }
}

define parse-string(k: &parser-kit) -> parsed(pair(string, comment)) {
  let r = Right(Unit); // fixme
  try _ = r;
  lexeme(k, (k) => {
    try _ =
      zonk.parse.satisfy("double quote", (r) => {
        eq-rune(r, `"`)
      })(k);
    _string-inner(k, core.vector.make(8))
  })
}
