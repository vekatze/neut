{
  target {
    mim {
      main "mim.nt",
      allocator "mimalloc",
    },
    mim-sys {
      main "mim.nt",
      allocator "system",
    },
  },
  dependency {
    core {
      digest "oM5OtbfvRGiO7xYuLcoDKKHDd1UrDaS8daPRusBh9fY",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-55-15.tar.zst",
      ],
      enable-preset true,
    },
  },
}
