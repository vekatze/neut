{
  target {
    mim {
      main "mim.nt",
      allocator "mimalloc",
    },
    mim-sys {
      main "mim.nt",
      allocator "system",
    },
  },
  dependency {
    core {
      digest "BOTWD7HQ5qOPuoPlx56QkXgynyN5ZSgNtoHHFmvakz0",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-54-1.tar.zst",
      ],
      enable-preset true,
    },
  },
}
