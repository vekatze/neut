{
  target {
    mim {
      main "mim.nt",
      allocator "mimalloc",
    },
    mim-sys {
      main "mim.nt",
      allocator "system",
    },
  },
  dependency {
    core {
      digest "yNWbpR6FH89l8vrvc2fh4PMZYlLEGtCzBHxT8aZQS5o",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-54-9.tar.zst",
      ],
      enable-preset true,
    },
  },
}
