{
  target {
    mim {
      main "mim.nt",
      allocator "mimalloc",
    },
    mim-sys {
      main "mim.nt",
      allocator "system",
    },
  },
  dependency {
    core {
      digest "GKmi5E12FLZUuCxhHX2f65YsMYnGwrS6U6maZlhUhh4",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-55-3.tar.zst",
      ],
      enable-preset true,
    },
  },
}
