{
  target {
    multi-targets {
      main "multi-targets.nt",
      build-option [
        "-fsanitize=address",
      ],
    },
    other-target {
      main "main.nt",
    },
  },
  dependency {
    core {
      digest "InilvGTJPse1sb_5P-AwJFyK0Ma3ogvUPCLMgdHz8Q0",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-55-27.tar.zst",
      ],
      enable-preset true,
    },
  },
}
