{
  target {
    multi-targets {
      main "multi-targets.nt",
      build-option [
        "-fsanitize=address",
      ],
    },
    other-target {
      main "main.nt",
    },
  },
  dependency {
    core {
      digest "jxVm7s8KCUWEygoBklH-pRjhPE40t_RRB0_-JG6rVeM",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-53-0.tar.zst",
      ],
      enable-preset true,
    },
  },
}
