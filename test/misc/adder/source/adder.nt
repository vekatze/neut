import {
  core::int.io {print-int-line},
}

define make-adder(x: int) -> (int) -> int {
  let adder =
    (y) => {
      add-int(x, y)
    };
  adder
}

define main() -> unit {
  print-int-line(make-adder(3)(7));
}

define-meta use-switch(k: 'int, !x: 'string) -> 'unit {
  let _: 'string = magic make-switch(k, x, List::[Pair(1, x)]);
  quote {Unit}
}

define hello() -> unit {
  // let str = use-switch::(10, *"hello");
  Unit
}
