import {
  core.box {axiom-T},
  core.cell {borrow, make-cell, mutate},
  core.int.io {print-int-line},
  core.list {length},
}

define bar(xs-cell: &cell(list(int))): unit {
  borrow(xs-cell, function (xs) {
    let len = length(xs);
    print-int-line(len);
    lift {Unit}
  })
}

define main(): unit {
  let xs: list(int) = Cons(1, Cons(2, Nil));
  let xs-cell = make-cell(lift {xs});
  let _ on xs-cell = {
    let _ = bar(xs-cell);
    mutate(xs-cell, function (xs) {
      lift {Cons(4, axiom-T(xs))}
    });
    let _ = bar(xs-cell);
    mutate(xs-cell, function (_) {
      lift {Nil}
    });
    mutate(xs-cell, function (xs) {
      lift {Cons(4, axiom-T(xs))}
    });
    bar(xs-cell)
  };
  let _ = xs-cell;
  Unit
}
