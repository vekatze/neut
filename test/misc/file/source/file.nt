import {
  core::file.access-mode {Read-Write},
  core::file.descriptor {close, open},
  core::string.io {read, write},
  core::system {system},
}

define use-file() -> system(unit) {
  try file = open("./test", Read-Write);
  try _ = write(file, "hey\n");
  try _ = read(file, 1024);
  close(file)
}

define main() -> unit {
  match use-file() {
  | Right(_) =>
    Unit
  | Left(_) =>
    Unit
  }
}
