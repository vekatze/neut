import {
  core::debug {assert, panic},
  core::doc {
    Chunk,
    Chunk-Choose,
    Chunk-Empty,
    Chunk-Join,
    Chunk-Line,
    Chunk-Style,
    Chunk-Style-N,
    Group,
    Nest,
    Seq,
    chunk,
    doc,
  },
  core::doc.show {show-doc},
  core::int.io {print-int-line},
  core::show.generic {to-doc},
  core::vector {access, from-list, length},
}

define _simplify-chunk(x: chunk) -> chunk {
  match x {
  | Chunk-Line =>
    Chunk-Empty
  | Chunk-Join(left, right) =>
    Chunk-Join(_simplify-chunk(left), _simplify-chunk(right))
  | Chunk-Choose(horizontal, _) =>
    horizontal
  | Chunk-Style(_) =>
    Chunk-Empty
  | Chunk-Style-N(_) =>
    Chunk-Empty
  | x =>
    x
  }
}

define _simplify-doc(d: doc) -> doc {
  match d {
  | Chunk(c) =>
    Chunk(_simplify-chunk(c))
  | Seq(d1, d2) =>
    Seq(_simplify-doc(d1), _simplify-doc(d2))
  | Nest(i, d) =>
    Nest(i, _simplify-doc(d))
  | Group(d) =>
    Group(_simplify-doc(d))
  }
}

inline-meta vet-simple<a>(x: '&a)[ribbon-length: 'int := quote {50}] -> 'unit {
  quote {
    let tmp = unquote {to-doc(x)};
    pin tmp = _simplify-doc(tmp);
    pin item = show-doc(tmp, unquote {ribbon-length});
    print(item);
    print("\n");
  }
}

define default-top<a>(x: int)[y: either(a, unit) := Right(Unit), z: bool := True] -> int {
  match y {
  | Left(_) =>
    print-line("left");
  | Right(_) =>
    print-line("right");
  };
  if z {
    print-line("true")
  } else {
    print-line("false")
  };
  x
}

define call-default-top() -> unit {
  let v1 = default-top<unit>(10);
  print-int-line(v1);
  let v2 = default-top<unit>(10)[y := Left(Unit)];
  print-int-line(v2);
  let v3 = default-top<unit>(10)[z := False];
  print-int-line(v3);
  let v4 = default-top<unit>(10)[y := Left(Unit), z := False];
  print-int-line(v4);
  let f =
    (x) => {
      default-top<unit>(x)
    };
  let v5 = f(10);
  print-int-line(v5);
}

define default-list<a>()[xs: list(a) := Nil] -> list(a) {
  xs
}

define call-default-list() -> unit {
  pin result = default-list<int>();
  vet-simple::(result)
}

inline local-lambda-default<a>(x: a) -> a {
  let f =
    ()[r: either(a, unit) := Right(Unit)] => {
      match r {
      | Left(_) =>
        print-line("left");
      | Right(_) =>
        print-line("right");
      };
      x
    };
  f()
}

define call-local-lambda-default() -> unit {
  pin v = local-lambda-default<unit>(Unit);
  vet-simple::(v)
}

define local-lambda-override(!u: string) -> unit {
  let !f =
    define tmp()[r := Right(u)] -> unit {
      match r {
      | Left(_) =>
        print-line("left");
      | Right(_) =>
        print-line("right");
      };
      Unit
    };
  pin v1 = f();
  vet-simple::(v1);
  pin v2 = f()[r := Left(Unit)];
  vet-simple::(v2);
}

inline local-define-default<a>(x: a) -> a {
  let g =
    define _(v: a)[r: either(a, unit) := Right(Unit)] -> a {
      let _ = r;
      v
    };
  g(x)
}

define takes-default-fun<a>(f: (x: int)[y: either(a, unit)] -> int) -> int {
  f(1)
}

define use-takes-default-fun() -> int {
  let _ =
    takes-default-fun<unit>((x)[y: either(unit, unit) := Right(Unit)] => {
      let _ = y;
      x
    });
  0
}

inline inline-default(x: int)[y: int := 1, z: int := 2] -> int {
  add-int(x, add-int(y, z))
}

define call-inline-default() -> unit {
  let v1 = inline-default(10);
  let v2 = inline-default(10)[z := 5];
  print-int-line(v1);
  print-int-line(v2);
}

define expect-int(label: &string, actual: int, expected: int) -> unit {
  assert(label, eq-int(actual, expected))
}

define expect-vector-2(label: &string, xs: &vector(int), x0: int, x1: int) -> unit {
  expect-int(label, length(xs), 2);
  match access(xs, 0) {
  | Left(_) =>
    panic(label)
  | Right(actual) =>
    expect-int(label, *actual, x0)
  };
  match access(xs, 1) {
  | Left(_) =>
    panic(label)
  | Right(actual) =>
    expect-int(label, *actual, x1)
  }
}

define dependent-default-top(x: int)[
  base: int := add-int(x, 1),
  step: int := add-int(base, x),
  result: int := add-int(step, base),
] -> int {
  result
}

define call-dependent-default-top() -> unit {
  expect-int("dependent-default-top: all omitted\n", dependent-default-top(3), 11);
  expect-int("dependent-default-top: first override flows forward\n", dependent-default-top(3)[base := 10], 23);
  expect-int("dependent-default-top: middle override keeps earlier default\n", dependent-default-top(3)[step := 20], 24);
  expect-int("dependent-default-top: last override wins\n", dependent-default-top(3)[result := 30], 30);
  expect-int("dependent-default-top: sparse overrides\n", dependent-default-top(3)[base := 10, result := 40], 40)
}

define stepper(x: int)[step: int := 1] -> int {
  add-int(x, step)
}

define higher-order-default(f: (x: int)[step: int] -> int)[
  arg: int := 5,
  step: int := add-int(arg, 2),
  result: int := f(arg)[step],
] -> int {
  result
}

define call-higher-order-default() -> unit {
  expect-int("higher-order-default: all omitted\n", higher-order-default(stepper), 12);
  expect-int("higher-order-default: explicit arg feeds later defaults\n", higher-order-default(stepper)[arg := 10], 22);
  expect-int("higher-order-default: explicit step feeds function default call\n", higher-order-default(stepper)[step := 2], 7);
  expect-int("higher-order-default: explicit result wins\n", higher-order-default(stepper)[result := 99], 99)
}

define call-local-dependent-defaults(anchor: int) -> unit {
  let !f =
    (x)[
      lo: int := add-int(anchor, x),
      hi: int := add-int(lo, x),
      total: int := add-int(lo, hi),
    ] => {
      total
    };
  expect-int("local dependent defaults: all omitted\n", f(2), 20);
  expect-int("local dependent defaults: first override\n", f(2)[lo := 10], 22);
  expect-int("local dependent defaults: last override\n", f(2)[total := 50], 50)
}

inline inline-dependent-default(x: int)[
  y: int := add-int(x, 1),
  z: int := mul-int(y, 2),
  w: int := add-int(z, y),
] -> int {
  add-int(w, x)
}

define call-inline-dependent-default() -> unit {
  expect-int("inline dependent defaults: all omitted\n", inline-dependent-default(4), 19);
  expect-int("inline dependent defaults: first override\n", inline-dependent-default(4)[y := 10], 34);
  expect-int("inline dependent defaults: middle override\n", inline-dependent-default(4)[z := 7], 16);
  expect-int("inline dependent defaults: last override\n", inline-dependent-default(4)[w := 8], 12)
}

inline-meta default-meta(x: 'int)[n: 'int := quote {0}] -> 'int {
  quote {add-int(unquote {x}, unquote {n})}
}

define use-default-meta() -> unit {
  let result = default-meta::(1);
  print-int-line(result);
  let result-overridden = default-meta::(1)[n := 41];
  print-int-line(result-overridden)
}

inline-meta meta-add(x: 'int, y: 'int) -> 'int {
  quote {add-int(unquote {x}, unquote {y})}
}

inline-meta dependent-default-meta(x: 'int)[
  lo: 'int := quote {add-int(unquote {x}, 2)},
  hi: 'int := meta-add(lo, x),
  total: 'int := quote {add-int(unquote {lo}, unquote {hi})},
] -> 'int {
  quote {add-int(unquote {total}, 100)}
}

inline-meta inline-dependent-default-meta(x: 'int)[
  delta: 'int := quote {add-int(unquote {x}, 1)},
  answer: 'int := meta-add(x, delta),
] -> 'int {
  quote {add-int(unquote {answer}, 2000)}
}

inline-meta vector-from-defaults(lo: 'int, hi: 'int) -> 'vector(int) {
  quote {
    let lo0 = unquote {lo};
    let hi0 = unquote {hi};
    from-list(Cons(lo0, Cons(hi0, Nil)))
  }
}

inline-meta dependent-default-vector(seed: 'int)[
  lo: 'int := quote {sub-int(unquote {seed}, 1)},
  hi: 'int := quote {add-int(unquote {lo}, 4)},
  expected-lo: 'int := lo,
  expected-hi: 'int := hi,
  xs: 'vector(int) := vector-from-defaults(expected-lo, expected-hi),
] -> 'unit {
  quote {
    pin xs = unquote {xs};
    expect-vector-2("dependent-default-vector\n", xs, unquote {expected-lo}, unquote {expected-hi})
  }
}

define use-dependent-default-meta() -> unit {
  expect-int("dependent-default-meta: all omitted\n", dependent-default-meta::(3), 113);
  expect-int("dependent-default-meta: first override flows forward\n", dependent-default-meta::(3)[lo := 10], 123);
  expect-int("dependent-default-meta: middle override keeps earlier default\n", dependent-default-meta::(3)[hi := 20], 125);
  expect-int("dependent-default-meta: last override wins\n", dependent-default-meta::(3)[total := 30], 130);
  expect-int("inline-dependent-default-meta: all omitted\n", inline-dependent-default-meta::(3), 2007);
  expect-int("inline-dependent-default-meta: first default override\n", inline-dependent-default-meta::(3)[delta := 10], 2013);
  expect-int("inline-dependent-default-meta: second default override\n", inline-dependent-default-meta::(3)[answer := 20], 2020);
  dependent-default-vector::(10);
  dependent-default-vector::(10)[lo := 40];
  dependent-default-vector::(10)[hi := 50];
  dependent-default-vector::(10)[expected-lo := 1, expected-hi := 2, xs := from-list(Cons(1, Cons(2, Nil)))]
}

define main() -> unit {
  call-default-top();
  call-default-list();
  call-local-lambda-default();
  local-lambda-override(*"test");
  pin v = local-define-default(*"lorem");
  print-line(v);
  call-inline-default();
  use-default-meta();
  call-dependent-default-top();
  call-higher-order-default();
  call-local-dependent-defaults(7);
  call-inline-dependent-default();
  use-dependent-default-meta();
}

define zen() -> unit {
  main()
}
