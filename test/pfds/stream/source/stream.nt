import {
  core.bool,
  core.unit {Unit, unit},
}

nominal {
  data stream(a: type),
}

data stream-cell(a) {
| Nil
| Cons(a, stream(a))
}

data stream(a) {
| Stream(() -> stream-cell(a))
}

define append<a>(xs: stream(a), ys: stream(a)) -> stream(a) {
  let Stream(k) = xs;
  match k() {
  | Nil =>
    ys
  | Cons(x1, rest) =>
    Stream(() => {
      Cons(x1, append<a>(rest, ys))
    })
  }
}

define take<a>(n: int, xs: stream(a)) -> stream(a) {
  if eq-int(n, 0) {
    Stream(() => {
      Nil
    })
  } else {
    let Stream(k) = xs;
    match k() {
    | Nil =>
      Stream(() => {
        Nil
      })
    | Cons(x, rest) =>
      Stream(() => {
        Cons(x, take<a>(sub-int(n, 1), rest))
      })
    }
  }
}

define main() -> unit {
  let my-stream: stream(int) =
    Stream(() => {
      Cons(1, Stream(() => {
        Nil
      }))
    });
  let _ = my-stream;
  Unit
}
