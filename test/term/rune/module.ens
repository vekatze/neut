{
  target {
    rune {
      main "rune.nt",
      build-option [
        "-fsanitize=address",
      ],
    },
  },
  dependency {
    core {
      digest "AgQUnWYjA_bcHUBnjW8Lu_gmpIDfzrDY2WDrYdgZR8E",
      mirror [
        "https://github.com/vekatze/neut-core/raw/main/archive/0-52-0.tar.zst",
      ],
      enable-preset true,
    },
  },
}
