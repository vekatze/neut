define test-syntax() -> unit {
  // nullary
  let _ =
    () => {
      pack-type {type}
    };
  // unary
  let _: (type) -> type =
    (x) => {
      x
    };
  let _ =
    (x: type) => {
      x
    };
  // binary
  let _: (type, type) -> type =
    (x, _) => {
      x
    };
  let _: (type, type) -> type =
    (_, y) => {
      y
    };
  let _: (type, type) -> type =
    (x: type, _) => {
      x
    };
  let _: (type, type) -> type =
    (_, y: type) => {
      y
    };
  let _: (type, type) -> type =
    (x: type, _) => {
      x
    };
  let _ =
    (x: type, y: type) => {
      Pair(x, y)
    };
  // exprs in bodies
  let _ =
    (f: (type) -> type) => {
      f(pack-type {type})
    };
  let _ =
    (f: (type) -> type) => {
      let _ = f(pack-type {type});
      pack-type {type}
    };
  let _ =
    (_: (type) -> type) => {
      Unit;
      Unit
    };
  // (unnecessarily) complex type
  let _ =
    (
      x: {(type, type) -> type},
      _: {(type) -> type},
    ) => {
      x
    };
  let f =
    (_: type, _: type, _: type) => {
      pack-type {type}
    };
  let _ =
    f(
      {
        let _ = pack-type {type};
        pack-type {type}
      },
      pack-type {type},
      {
        let f =
          () => {
            pack-type {type}
          };
        f()
      },
    );
  Unit
}

define sample() -> type {
  let _ = pack-type {type};
  Unit;
  pack-type {(type, type) -> type}
}

define opaque<a>(x: a) -> a {
  x
}

define affine-lam1() -> unit {
  let lam1 =
    opaque(() => {
      pack-type {type}
    });
  let _ = lam1;
  Unit
}

define relevant-lam1() -> unit {
  let !lam1 =
    opaque(() => {
      pack-type {type}
    });
  let _ = lam1;
  let _ = lam1;
  Unit
}

define affine-lam2() -> unit {
  let lam1 =
    opaque(() => {
      pack-type {type}
    });
  let lam2 =
    opaque(() => {
      let v = lam1;
      v
    });
  let _ = lam2;
  Unit
}

define relevant-lam2() -> unit {
  let lam1 =
    opaque(() => {
      pack-type {type}
    });
  let !lam2 =
    opaque(() => {
      let v = lam1;
      v
    });
  let _ = lam2;
  let _ = lam2;
  Unit
}

define affine-lam3() -> unit {
  let !lam1 =
    opaque(() => {
      pack-type {type}
    });
  let lam2 =
    opaque(() => {
      let v = lam1;
      v
    });
  let lam3 =
    opaque((_: (type) -> type) => {
      let _ = lam1;
      let v2 = lam2;
      v2
    });
  let _ = lam3;
  Unit
}

define relevant-lam3() -> unit {
  let !lam1 =
    opaque(() => {
      pack-type {type}
    });
  let lam2 =
    opaque(() => {
      let v = lam1;
      v
    });
  let !lam3 =
    opaque((_: (type) -> type) => {
      let _ = lam1;
      let v2 = lam2;
      v2
    });
  let _ = lam3;
  let _ = lam3;
  Unit
}

