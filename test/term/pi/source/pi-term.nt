define test-reduction() -> unit {
  Unit
}

define test-resource() -> unit {
  affine-lam1();
  relevant-lam1();
  affine-lam2();
  relevant-lam2();
  affine-lam3();
  relevant-lam3();
  affine-lam4();
  relevant-lam4()
