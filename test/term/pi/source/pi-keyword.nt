import {
  core.null {null},
}

define foo(
  FOO: bool,
  a: type,
  🌟🌟🌟: type,
  竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね: int,
)->
type {
  let _ = 竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね;
  if FOO {
    unpack-type a = a;
    unpack-type 🌟🌟🌟 = 🌟🌟🌟;
    pack-type {(a) -> 🌟🌟🌟}
  } else {
    unpack-type 🌟🌟🌟 = 🌟🌟🌟;
    pack-type {(🌟🌟🌟) -> type}
  }
}

define bar<a>(some-value: a) -> unit {
  let _ = some-value;
  Unit
}

define test-syntax() -> unit {
  let _ =
    foo{
      a := pack-type {int},
      FOO := True,
      🌟🌟🌟 := pack-type {list(null)},
      竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね := {
        let x = 10;
        let y = 20;
        add-int(x, y)
      },
    };
  let _ =
    foo{
      a := pack-type {int},
      🌟🌟🌟 := pack-type {list(null)},
      FOO := False,
      竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね := {
        let x = 10;
        let y = 20;
        add-int(x, y)
      },
    };
  let _ =
    foo{
      🌟🌟🌟 := pack-type {list(null)},
      a := {
        foo{
          竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね := {
            let x = 10;
            let y = 20;
            add-int(x, y)
          },
          a := pack-type {int},
          🌟🌟🌟 := pack-type {list(null)},
          FOO := True,
        }
      },
      FOO := False,
      竹の葉に霰ふるなりさらさらに独りは寝べき心地こそせね := {
        let x = 10;
        let y = 20;
        add-int(x, y)
      },
    };
  let _ =
    // hole-notation + keyword arguments
    bar{
      some-value := pack-type {type},
    };
  Unit
}

define def-func-using-of(
  arg-1: int,
  arg-2: type,
)->
type {
  let _ = arg-1;
  arg-2
}
