import {
  this.pi-keyword,
  this.pi-term,
}

define test-syntax() -> unit {
  // nullary
  let _ = pack-type {() -> type};
  // general, non-dependent
  let _ = pack-type {(type) -> type};
  let _ = pack-type {(() -> type) -> type};
  let _ = pack-type {(() -> (type) -> type) -> type};
  let _ = pack-type {(((type) -> type) -> type) -> type};
  // general, dependent
  let _ = pack-type {(a: type, a) -> a};
  let _ = pack-type {(a: type, a) -> a};
  let _ = pack-type {(a: type, a) -> list(type)};
  let _ = pack-type {(a: type, list(type)) -> a};
  let _ = pack-type {(a: type, a) -> &list(type)};
  let _ = pack-type {(a: type, &list(type)) -> a};
  let _ = pack-type {(a: type, a) -> thread(list(type))};
  let _ = pack-type {(a: type, thread(list(type))) -> a};
  let _ = pack-type {(a: type, a) -> type};
  let _ = pack-type {(a: type, (a) -> a) -> type};
  let _ = pack-type {(a: type, ((a) -> a) -> a) -> type};
  // simplified
  let _ = pack-type {(type) -> type};
  let _ = pack-type {({(type) -> type}) -> type};
  let _ = pack-type {(type) -> (type) -> list(type)};
  let _ = pack-type {(type) -> {(type) -> type}};
  let _ = pack-type {(type) -> {(type) -> list(type)}};
  let _ = pack-type {(type) -> {(list(type)) -> type}};
  let _ = pack-type {(type) -> {(type) -> &list(type)}};
  let _ = pack-type {(type) -> {(&list(type)) -> type}};
  let _ = pack-type {(type) -> {(type) -> thread(list(type))}};
  let _ = pack-type {(type) -> {(thread(list(type))) -> type}};
  let _ = pack-type {(type) -> {({(type) -> type}) -> type}};
  let _ = pack-type {(type) -> {(type) -> {(type) -> type}}};
  let _ = pack-type {(type) -> {({(type) -> type}) -> {(type) -> type}}};
  let _ = pack-type {({(type) -> type}) -> {({(type) -> type}) -> {(type) -> type}}};
  let _ = pack-type {({({(type) -> type}) -> {(type) -> type}}) -> {({(type) -> type}) -> {(type) -> type}}};
  // complex
  let _ = pack-type {(a: type, m: (type, type) -> type) -> ({(s: type) -> (a) -> m(s, a)}) -> a};
  Unit
}

define affine-pi() -> type {
  let _ = pack-type {(type) -> type};
  pack-type {type}
}

define linear-pi() -> type {
  let x = pack-type {(type) -> type};
  x
}

define relevant-pi() -> type {
  let x = pack-type {(type) -> type};
  let _ = x;
  x
}

define test-resource() -> unit {
  let _ = affine-pi();
  let _ = linear-pi();
  let _ = relevant-pi();
  Unit
}

define main() -> unit {
  test-syntax();
  test-resource();
  this.pi-term.test-syntax();
  this.pi-term.test-resource();
  this.pi-keyword.test-syntax()
}
