import {
  core.null {null},
}

define test-syntax(): type {
  let _: type = pack-type {type};
  let _: type = pack-type {type};
  pack-type {type}
}

define affine-type(): type {
  let _ = pack-type {type};
  pack-type {type}
}

define linear-type(): type {
  let x = pack-type {type};
  x
}

define relevant-type(): type {
  let x = pack-type {type};
  let _ = x;
  x
}

define type-is-type(): type {
  pack-type {type}
}

define pi-is-type(): type {
  let _: type = pack-type {() -> type};
  let _: type = pack-type {(type) -> type};
  let _: type = pack-type {(type, type, type) -> type};
  pack-type {type}
}

define data-is-type(): type {
  let _: type = pack-type {null};
  let _: type = pack-type {unit};
  let _: type = pack-type {bool};
  let _: type = pack-type {list(type)};
  pack-type {type}
}

define noema-is-type(a: type): type {
  unpack-type a = a;
  pack-type {&a}
}

define thread-is-type(a: type): type {
  unpack-type a = a;
  pack-type {thread(a)}
}

define resource-is-type(): type {
  let _: type = pack-type {text};
  let _: type = pack-type {vector(text)};
  pack-type {type}
}

define test-semantics(): type {
  let _ = affine-type();
  let _ = linear-type();
  let _ = relevant-type();
  let _ = type-is-type();
  let _ = pi-is-type();
  let _ = data-is-type();
  let _ = noema-is-type(pack-type {type});
  let _ = thread-is-type(pack-type {type});
  let _ = resource-is-type();
  pack-type {type}
}

define main(): unit {
  let _ = test-syntax();
  let _ = test-semantics();
  Unit
}
